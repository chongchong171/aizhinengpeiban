<!--
  读给你听页面（原瓜瓜读给你听）
  @description TTS 朗读功能，AI 为你朗读文章、故事
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：瓜瓜读给你听 → 读给你听
-->

<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <!-- 【女性审美优化】瓜瓜读给你听 → 读给你听 -->
    <text class="page-title">🎧 读给你听</text>
    <text class="page-desc">让温暖的声音陪伴你</text>
  </view>

  <!-- 播放控制区域 -->
  <view class="player-section">
    <view class="player-card">
      <!-- 瓜瓜形象 -->
      <view class="player-avatar">
        <image 
          class="avatar-image" 
          src="/images/treehole/treehole-main.png" 
          mode="aspectFit"
        />
      </view>

      <!-- 播放状态 -->
      <view class="player-status">
        <text class="status-text">{{isPlaying ? '正在朗读...' : '准备播放'}}</text>
        <text class="status-sub">{{currentContent || '选择内容开始朗读'}}</text>
      </view>

      <!-- 播放控制按钮 -->
      <view class="player-controls">
        <button class="control-btn" bindtap="stopPlay" disabled="{{!isPlaying}}">
          <text class="control-icon">⏹️</text>
        </button>
        <button class="control-btn play-btn" bindtap="togglePlay">
          <text class="control-icon">{{isPlaying ? '⏸️' : '▶️'}}</text>
        </button>
        <button class="control-btn" bindtap="selectContent">
          <text class="control-icon">📋</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 内容选择区域 -->
  <view class="section">
    <view class="section-title">选择朗读内容</view>
    
    <!-- 内容分类 -->
    <view class="category-tabs">
      <view 
        class="tab-item {{currentCategory === 'stories' ? 'active' : ''}}" 
        bindtap="switchCategory" 
        data-category="stories"
      >
        睡前故事
      </view>
      <view 
        class="tab-item {{currentCategory === 'articles' ? 'active' : ''}}" 
        bindtap="switchCategory" 
        data-category="articles"
      >
        文章
      </view>
      <view 
        class="tab-item {{currentCategory === 'custom' ? 'active' : ''}}" 
        bindtap="switchCategory" 
        data-category="custom"
      >
        自定义
      </view>
    </view>

    <!-- 内容列表 -->
    <view class="content-list">
      <view 
        class="content-item {{currentContent === item.title ? 'active' : ''}}" 
        wx:for="{{contentList}}" 
        wx:key="id"
        bindtap="selectContentItem"
        data-item="{{item}}"
      >
        <text class="content-icon">{{item.icon}}</text>
        <view class="content-info">
          <text class="content-title">{{item.title}}</text>
          <text class="content-desc">{{item.duration}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义输入 -->
  <view class="section" wx:if="{{currentCategory === 'custom'}}">
    <view class="section-title">自定义内容</view>
    <view class="custom-input-card">
      <textarea 
        class="custom-input" 
        placeholder="输入你想让瓜瓜读的内容..."
        value="{{customText}}"
        bindinput="onCustomInput"
        maxlength="1000"
      />
      <button class="read-custom-btn" bindtap="readCustom">开始朗读</button>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="section">
    <view class="section-title">朗读设置</view>
    <view class="settings-list">
      <view class="setting-item">
        <text class="setting-label">语速</text>
        <slider 
          class="setting-slider" 
          min="0.5" 
          max="2" 
          step="0.1" 
          value="{{speed}}"
          bindchange="onSpeedChange"
          show-value
        />
      </view>
      <view class="setting-item">
        <text class="setting-label">音量</text>
        <slider 
          class="setting-slider" 
          min="0" 
          max="100" 
          value="{{volume}}"
          bindchange="onVolumeChange"
          show-value
        />
      </view>
    </view>
  </view>
</view>
