/**
 * 瓜瓜读给你听页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
}

/* 播放器区域 */
.player-section {
  margin-bottom: 30rpx;
}

.player-card {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player-avatar {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.avatar-image {
  width: 180rpx;
  height: 180rpx;
  object-fit: contain;
}

.player-status {
  text-align: center;
  margin-bottom: 30rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.status-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.player-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
}

.control-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  border: none;
}

.control-btn:active {
  background-color: rgba(255, 255, 255, 0.5);
}

.control-btn[disabled] {
  opacity: 0.5;
}

.play-btn {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.9);
}

.control-icon {
  font-size: 48rpx;
}

/* 内容选择区域 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  color: #fff;
  font-weight: 600;
}

/* 内容列表 */
.content-list {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 20rpx;
}

.content-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
  background-color: rgba(255, 255, 255, 0.7);
  transition: all 0.2s;
}

.content-item:last-child {
  margin-bottom: 0;
}

.content-item.active {
  background: linear-gradient(135deg, #FFE4E8 0%, #FFD6DE 100%);
  border: 2rpx solid #FF6B81;
}

.content-item:active {
  transform: scale(0.98);
}

.content-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.content-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.content-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.content-desc {
  font-size: 24rpx;
  color: #999;
}

/* 自定义输入 */
.custom-input-card {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 30rpx;
}

.custom-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.read-custom-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  width: 100%;
}

/* 设置列表 */
.settings-list {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 20rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 107, 129, 0.1);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.setting-slider {
  flex: 1;
}
