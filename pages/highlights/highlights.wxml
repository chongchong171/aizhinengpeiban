<!--
  今日亮点页面
  @description 展示今日成就和美好瞬间
  @author 玄枢
  @date 2026-03-15
-->

<view class="container">
  <!-- 日期标题 -->
  <view class="header">
    <text class="date">{{todayDate}}</text>
    <text class="title">今日亮点 ✨</text>
    <text class="subtitle">记录每一个闪闪发光的瞬间</text>
  </view>

  <!-- 今日成就卡片 -->
  <view class="achievements-section">
    <view class="section-title">🏆 今日成就</view>
    
    <view class="achievement-list">
      <block wx:for="{{achievements}}" wx:key="id">
        <view class="achievement-item">
          <view class="achievement-icon">{{item.icon}}</view>
          <view class="achievement-content">
            <text class="achievement-text">{{item.content}}</text>
            <text class="achievement-time">{{item.time}}</text>
          </view>
        </view>
      </block>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{achievements.length === 0}}">
        <text class="empty-icon">📝</text>
        <text class="empty-text">今天还没有记录成就呢</text>
        <text class="empty-hint">点击底部按钮添加第一个成就吧！</text>
      </view>
    </view>
  </view>

  <!-- 情绪总结卡片 -->
  <view class="mood-section card">
    <view class="section-title">💖 今日心情</view>
    <view class="mood-display">
      <text class="mood-emoji">{{currentMood.emoji}}</text>
      <text class="mood-text">{{currentMood.text}}</text>
    </view>
    <view class="mood-stats">
      <text class="stat-item">开心时刻：{{moodStats.happy}}</text>
      <text class="stat-item">平静时刻：{{moodStats.calm}}</text>
      <text class="stat-item">感动时刻：{{moodStats.touched}}</text>
    </view>
  </view>

  <!-- 瓜瓜的鼓励 -->
  <view class="encouragement-card card">
    <view class="encouragement-icon">🐾</view>
    <text class="encouragement-text">{{encouragement}}</text>
  </view>

  <!-- 底部添加按钮 -->
  <view class="add-button safe-area-bottom" bindtap="showAddAchievement">
    <text class="add-icon">+</text>
    <text class="add-text">记录成就</text>
  </view>
  
  <!-- 添加成就自定义弹窗 -->
  <view class="custom-dialog-mask" wx:if="{{showDialog}}" catchtap="cancelAddAchievement">
    <view class="custom-dialog" catchtap="e">
      <view class="dialog-title">记录今日亮点</view>
      <view class="dialog-content">
        <input 
          class="dialog-input" 
          type="text" 
          placeholder="今天完成了什么值得骄傲的事？" 
          value="{{newAchievement}}"
          bindinput="onAchievementInput"
          focus="{{showDialog}}"
        />
      </view>
      <view class="dialog-footer">
        <view class="dialog-cancel" bindtap="cancelAddAchievement">取消</view>
        <view class="dialog-confirm" bindtap="confirmAddAchievement">确定</view>
      </view>
    </view>
  </view>
</view>
