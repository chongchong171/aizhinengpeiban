/**
 * 今日亮点页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  padding: 40rpx 30rpx 160rpx;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 40rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
}

.date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 成就列表 */
.achievements-section {
  margin-bottom: 30rpx;
}

.achievement-list {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 24rpx;
}

.achievement-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FFE4E8;
}

.achievement-item:last-child {
  border-bottom: none;
}

.achievement-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.achievement-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.achievement-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.achievement-time {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 心情区域 */
.mood-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
}

.mood-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.mood-emoji {
  font-size: 100rpx;
  margin-right: 20rpx;
}

.mood-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.mood-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #FFE4E8;
}

.stat-item {
  font-size: 24rpx;
  color: #666;
}

/* 鼓励卡片 */
.encouragement-card {
  text-align: center;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.encouragement-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.encouragement-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 添加按钮 */
.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #FF6B81;
  color: #FFFFFF;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.4);
}

.add-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.add-text {
  font-size: 30rpx;
  font-weight: 600;
}

/* 弹窗输入框 */
.dialog-input {
  width: 100%;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #EEE;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

/* 自定义弹窗样式 */
.custom-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.custom-dialog {
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: dialogSlideIn 0.3s ease-out;
}

@keyframes dialogSlideIn {
  from {
    opacity: 0;
    transform: translateY(-50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.dialog-title {
  text-align: center;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #EEE;
}

.dialog-content {
  padding: 40rpx 30rpx;
}

.dialog-footer {
  display: flex;
  border-top: 1rpx solid #EEE;
}

.dialog-cancel,
.dialog-confirm {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #666;
}

.dialog-cancel {
  border-right: 1rpx solid #EEE;
  background-color: #F8F8F8;
}

.dialog-confirm {
  color: #FF6B81;
  font-weight: 600;
}
