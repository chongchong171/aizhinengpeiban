/* 我的优惠券页面样式 */
.container {
  min-height: 100vh;
  background: #FFF5F6;
  padding-bottom: 40rpx;
}

/* 选项卡 */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #FF6B81;
  color: #fff;
  font-weight: bold;
}

/* 优惠券列表 */
.coupon-list {
  padding: 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

.go-redeem-btn {
  background: #FF6B81;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.coupon-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.coupon-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.coupon-info {
  flex: 1;
}

.coupon-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.value-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-right: 8rpx;
}

.value-desc {
  font-size: 24rpx;
  color: #999;
}

.coupon-condition {
  font-size: 24rpx;
  color: #666;
  background: #FFF5F6;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 10rpx;
}

.coupon-discount {
  font-size: 24rpx;
  color: #999;
}

.coupon-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.coupon-status.unused {
  background: #E8F5E9;
  color: #4CAF50;
}

.coupon-status.used {
  background: #F5F5F5;
  color: #999;
}

.coupon-status.expired {
  background: #FFEBEE;
  color: #F44336;
}

.coupon-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.expire-info {
  font-size: 24rpx;
  color: #999;
}

.use-btn {
  background: #FF6B81;
  color: #fff;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}
