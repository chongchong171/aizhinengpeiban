<!--我的优惠券页面-->
<view class="container">
  <!-- 选项卡 -->
  <view class="tabs">
    <view class="tab {{currentTab === 'unused' ? 'active' : ''}}" bindtap="switchTab" data-tab="unused">
      可使用 ({{stats.unused}})
    </view>
    <view class="tab {{currentTab === 'used' ? 'active' : ''}}" bindtap="switchTab" data-tab="used">
      已使用 ({{stats.used}})
    </view>
    <view class="tab {{currentTab === 'expired' ? 'active' : ''}}" bindtap="switchTab" data-tab="expired">
      已过期 ({{stats.expired}})
    </view>
  </view>

  <!-- 优惠券列表 -->
  <view class="coupon-list">
    <view wx:if="{{coupons.length === 0}}" class="empty-state">
      <text class="empty-icon">🎫</text>
      <text class="empty-text">
        {{currentTab === 'unused' ? '暂无可用优惠券，快去积分商城兑换吧~' : 
          currentTab === 'used' ? '暂无已使用的优惠券' : '暂无过期的优惠券'}}
      </text>
      <view wx:if="{{currentTab === 'unused'}}" class="go-redeem-btn" bindtap="goToPointsShop">
        去兑换
      </view>
    </view>

    <view class="coupon-item" wx:for="{{coupons}}" wx:key="id" data-status="{{item.status}}">
      <view class="coupon-main">
        <view class="coupon-info">
          <view class="coupon-value">
            <text class="value-num">¥{{item.couponValue}}</text>
            <text class="value-desc">优惠券</text>
          </view>
          <view class="coupon-condition">满¥{{item.minPurchase}}可用</view>
          <view class="coupon-discount">{{item.discount}}</view>
        </view>
        
        <view class="coupon-status {{item.status}}">
          {{item.status === 'unused' ? '可使用' : item.status === 'used' ? '已使用' : '已过期'}}
        </view>
      </view>
      
      <view class="coupon-footer">
        <view class="expire-info">
          {{item.status === 'unused' ? '有效期：' + item.daysLeft + '天' : 
            item.status === 'used' ? '已使用' : '已过期'}}
        </view>
        <view wx:if="{{item.status === 'unused'}}" class="use-btn" bindtap="useCoupon" data-item="{{item}}">
          立即使用
        </view>
      </view>
    </view>
  </view>
</view>
