/* pages/decorationRanking/decorationRanking.wxss */
/* 装修排行榜页面 - 温暖治愈系粉色系风格 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E9 100%);
}

/* 顶部标题 */
.ranking-header {
  text-align: center;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFF;
  margin-bottom: 12rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

/* 排行榜前三甲 */
.top-three {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #FFE4E9 0%, #FFF5F7 100%);
}

.rank-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #FFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.rank-item:active {
  transform: scale(0.95);
}

.rank-1 {
  order: 2;
  transform: scale(1.1);
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 8rpx 32rpx rgba(255, 215, 0, 0.4);
}

.rank-2 {
  order: 1;
  background: linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%);
  box-shadow: 0 8rpx 24rpx rgba(192, 192, 192, 0.4);
}

.rank-3 {
  order: 3;
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
  box-shadow: 0 8rpx 24rpx rgba(205, 127, 50, 0.4);
}

.rank-avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.rank-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 6rpx solid #FFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.rank-1 .rank-avatar {
  width: 140rpx;
  height: 140rpx;
}

.rank-badge {
  position: absolute;
  bottom: -10rpx;
  right: -10rpx;
  font-size: 50rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.crown-icon {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 60rpx;
  animation: crownFloat 2s ease-in-out infinite;
}

@keyframes crownFloat {
  0%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  50% {
    transform: translateX(-50%) translateY(-10rpx);
  }
}

.rank-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-1 .rank-name {
  font-size: 30rpx;
  color: #FFF;
}

.rank-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-bottom: 8rpx;
}

.rank-1 .rank-score,
.rank-2 .rank-score,
.rank-3 .rank-score {
  color: #FFF;
}

.rank-dorm {
  font-size: 22rpx;
  color: #999;
}

.rank-1 .rank-dorm,
.rank-2 .rank-dorm,
.rank-3 .rank-dorm {
  color: rgba(255, 255, 255, 0.9);
}

/* 我的排名 */
.my-ranking {
  padding: 30rpx;
}

.my-rank-card {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  padding: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.3);
}

.my-rank-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.my-rank-info {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.my-rank-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFF;
  margin-right: 20rpx;
}

.my-rank-score {
  font-size: 28rpx;
  color: #FFF;
}

.view-btn {
  width: 100%;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #FFF 0%, #FFF8DC 100%);
  color: #FF69B4;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 30rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 排行榜列表 */
.ranking-list-section {
  flex: 1;
  padding: 0 30rpx 30rpx;
  overflow: hidden;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.ranking-scroll {
  height: calc(100vh - 600rpx);
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.ranking-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.ranking-item.top-rank {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4E9 100%);
  border: 2rpx solid #FFB6C1;
}

.item-rank {
  width: 60rpx;
  text-align: center;
  margin-right: 20rpx;
}

.rank-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #999;
}

.rank-number.highlight {
  font-size: 36rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.item-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #FFB6C1;
  margin-right: 20rpx;
}

.item-details {
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.item-dorm {
  font-size: 22rpx;
  color: #999;
}

.item-score-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.item-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
}

.score-label {
  font-size: 20rpx;
  color: #999;
}

.item-decoration-preview {
  display: flex;
  gap: 8rpx;
}

.preview-img {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  border: 2rpx solid #FFB6C1;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.load-more {
  color: #FF69B4;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.modal-content {
  background: #FFF;
  border-radius: 30rpx;
  width: 90%;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-bottom: 2rpx solid #FF69B4;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFF;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.modal-close {
  font-size: 40rpx;
  color: #FFF;
  padding: 10rpx;
  line-height: 1;
}

/* 宿舍预览 */
.preview-modal {
  max-height: 70vh;
}

.preview-content {
  padding: 30rpx;
}

.preview-room {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  margin-bottom: 30rpx;
}

.preview-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #FFF5F7;
  border-radius: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF69B4;
}

.preview-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 2rpx solid #F5F5F5;
}

.action-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s;
}

.action-btn:active {
  transform: scale(0.95);
}

.cancel-btn {
  background: linear-gradient(135deg, #FFA07A 0%, #FF8C69 100%);
  color: #FFF;
  border: none;
}

.visit-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFF;
  border: none;
}
