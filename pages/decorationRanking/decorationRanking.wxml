<!--pages/decorationRanking/decorationRanking.wxml-->
<!-- 装修排行榜页面 -->

<view class="container">
  <!-- 顶部标题 -->
  <view class="ranking-header">
    <text class="header-title">🏆 装修排行榜</text>
    <text class="header-subtitle">看看谁的宿舍最漂亮</text>
  </view>

  <!-- 排行榜前三甲 -->
  <view class="top-three">
    <!-- 第二名 -->
    <view class="rank-item rank-2">
      <view class="rank-avatar-wrapper">
        <image class="rank-avatar" src="{{topRanking[1]?.avatar || '/images/avatar.png'}}" mode="aspectFill"></image>
        <view class="rank-badge">🥈</view>
      </view>
      <text class="rank-name">{{topRanking[1]?.name || '---'}}</text>
      <text class="rank-score">{{topRanking[1]?.score || 0}}</text>
      <text class="rank-dorm">{{topRanking[1]?.dormName || '---'}}</text>
    </view>
    
    <!-- 第一名 -->
    <view class="rank-item rank-1">
      <view class="rank-avatar-wrapper">
        <image class="rank-avatar" src="{{topRanking[0]?.avatar || '/images/avatar.png'}}" mode="aspectFill"></image>
        <view class="rank-badge">🥇</view>
        <view class="crown-icon">👑</view>
      </view>
      <text class="rank-name">{{topRanking[0]?.name || '---'}}</text>
      <text class="rank-score">{{topRanking[0]?.score || 0}}</text>
      <text class="rank-dorm">{{topRanking[0]?.dormName || '---'}}</text>
    </view>
    
    <!-- 第三名 -->
    <view class="rank-item rank-3">
      <view class="rank-avatar-wrapper">
        <image class="rank-avatar" src="{{topRanking[2]?.avatar || '/images/avatar.png'}}" mode="aspectFill"></image>
        <view class="rank-badge">🥉</view>
      </view>
      <text class="rank-name">{{topRanking[2]?.name || '---'}}</text>
      <text class="rank-score">{{topRanking[2]?.score || 0}}</text>
      <text class="rank-dorm">{{topRanking[2]?.dormName || '---'}}</text>
    </view>
  </view>

  <!-- 我的排名 -->
  <view class="my-ranking">
    <view class="my-rank-card">
      <text class="my-rank-label">我的排名</text>
      <view class="my-rank-info">
        <text class="my-rank-number">#{{myRanking.rank || '-'}}</text>
        <text class="my-rank-score">{{myRanking.score || 0}} 分</text>
      </view>
      <button class="view-btn" bindtap="viewMyDormitory">查看我的宿舍</button>
    </view>
  </view>

  <!-- 排行榜列表 -->
  <view class="ranking-list-section">
    <view class="list-header">
      <text class="list-title">排行榜</text>
      <text class="list-count">共 {{rankingList.length}} 个宿舍</text>
    </view>
    
    <scroll-view scroll-y class="ranking-scroll" enhanced="{{true}}" show-scrollbar="{{true}}">
      <view class="ranking-list">
        <block wx:for="{{rankingList}}" wx:key="rank">
          <view 
            class="ranking-item {{item.rank <= 3 ? 'top-rank' : ''}}"
            bindtap="viewDormitory"
            data-id="{{item.dormitoryId}}"
          >
            <view class="item-rank">
              <text class="rank-number {{item.rank <= 3 ? 'highlight' : ''}}">{{item.rank}}</text>
            </view>
            
            <view class="item-info">
              <image class="item-avatar" src="{{item.avatar || '/images/avatar.png'}}" mode="aspectFill"></image>
              <view class="item-details">
                <text class="item-name">{{item.name}}</text>
                <text class="item-dorm">{{item.dormName}}</text>
              </view>
            </view>
            
            <view class="item-score-wrapper">
              <text class="item-score">{{item.score}}</text>
              <text class="score-label">评分</text>
            </view>
            
            <view class="item-decoration-preview">
              <block wx:for="{{item.previewImages}}" wx:for-item="img" wx:key="*this">
                <image class="preview-img" src="{{img}}" mode="aspectFill"></image>
              </block>
            </view>
          </view>
        </block>
      </view>
      
      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
        <text>加载更多</text>
      </view>
      
      <!-- 没有更多 -->
      <view wx:if="{{!hasMore && rankingList.length > 0}}" class="no-more">
        <text>已经到底啦~</text>
      </view>
    </scroll-view>
  </view>

  <!-- 宿舍预览弹窗 -->
  <view wx:if="{{showPreview}}" class="modal-overlay" bindtap="closePreview">
    <view class="modal-content preview-modal" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">{{selectedDorm.name}}的宿舍</text>
        <text class="modal-close" bindtap="closePreview">✕</text>
      </view>
      
      <view class="preview-content">
        <image class="preview-room" src="{{selectedDorm.previewImage}}" mode="aspectFill"></image>
        <view class="preview-info">
          <view class="info-row">
            <text class="info-label">宿舍评分</text>
            <text class="info-value">{{selectedDorm.score}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">宿舍等级</text>
            <text class="info-value">Lv.{{selectedDorm.level}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">主人</text>
            <text class="info-value">{{selectedDorm.ownerName}}</text>
          </view>
        </view>
      </view>
      
      <view class="preview-actions">
        <button class="action-btn cancel-btn" bindtap="closePreview">关闭</button>
        <button class="action-btn visit-btn" bindtap="visitDormitory">去参观</button>
      </view>
    </view>
  </view>
</view>
