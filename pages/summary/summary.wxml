<!--
  今天的小确幸页面（原今日总结）
  @description 合并心情日记和今日亮点，展示每日总结
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：今日总结 → 今天的小确幸
-->

<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <!-- 【女性审美优化】今日总结 → 今天的小确幸 -->
    <text class="page-title">📊 今天的小确幸</text>
    <text class="page-date">{{currentDate}}</text>
  </view>

  <!-- 今日心情 -->
  <view class="section">
    <view class="section-title">今天的心情</view>
    <view class="mood-card">
      <view class="mood-display">
        <text class="mood-emoji">{{currentMood.emoji}}</text>
        <text class="mood-text">{{currentMood.text}}</text>
      </view>
    </view>
  </view>

  <!-- 今日亮点 -->
  <view class="section">
    <view class="section-title">✨ 今日亮点</view>
    <view class="highlights-list">
      <view class="highlight-item" wx:for="{{highlights}}" wx:key="index">
        <text class="highlight-icon">⭐</text>
        <text class="highlight-text">{{item}}</text>
      </view>
      <view class="add-highlight" bindtap="addHighlight">
        <text class="add-text">+ 添加亮点</text>
      </view>
    </view>
  </view>

  <!-- 心情日记 -->
  <view class="section">
    <view class="section-title">📝 心情日记</view>
    <view class="diary-card">
      <textarea 
        class="diary-input" 
        placeholder="今天有什么想记录的吗？"
        value="{{diaryContent}}"
        bindinput="onDiaryInput"
        maxlength="500"
      />
      <view class="diary-actions">
        <button class="save-btn" bindtap="saveDiary">保存日记</button>
      </view>
    </view>
  </view>

  <!-- 瓜瓜的鼓励 -->
  <view class="section">
    <view class="section-title">💌 瓜瓜的鼓励</view>
    <view class="encouragement-card">
      <text class="encouragement-text">{{encouragement}}</text>
    </view>
  </view>
</view>
