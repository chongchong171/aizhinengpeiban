<!--
  呼吸练习页面（深呼吸一下子功能）
  @description 动画引导呼吸练习，配合 TTS 语音和背景音
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：放松引导 → 深呼吸一下
-->

<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">🌬️ 呼吸练习</text>
    <text class="subtitle">4-7-8 呼吸法 · 放松身心</text>
  </view>

  <!-- 呼吸引导动画 -->
  <view class="breathing-section">
    <view class="breathing-circle {{breathingState}}">
      <view class="inner-circle">
        <text class="breath-icon">{{breathingIcon}}</text>
      </view>
    </view>
    <text class="breathing-text">{{breathingText}}</text>
    <text class="breathing-hint">{{breathingHint}}</text>
    
    <!-- 进度指示器 -->
    <view class="progress-dots">
      <view class="dot {{currentStep >= 1 ? 'active' : ''}}"></view>
      <view class="dot {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="dot {{currentStep >= 3 ? 'active' : ''}}"></view>
    </view>
  </view>

  <!-- 背景音选择 -->
  <view class="bgm-section">
    <text class="section-title">🎵 选择背景音</text>
    <view class="bgm-options">
      <view 
        class="bgm-item {{bgmSelected === 'none' ? 'active' : ''}}"
        bindtap="selectBGM"
        data-bgm="none"
      >
        <text class="bgm-icon">🔇</text>
        <text class="bgm-name">关闭</text>
      </view>
      <view 
        class="bgm-item {{bgmSelected === 'rain' ? 'active' : ''}}"
        bindtap="selectBGM"
        data-bgm="rain"
      >
        <text class="bgm-icon">🌧️</text>
        <text class="bgm-name">雨声</text>
      </view>
      <view 
        class="bgm-item {{bgmSelected === 'ocean' ? 'active' : ''}}"
        bindtap="selectBGM"
        data-bgm="ocean"
      >
        <text class="bgm-icon">🌊</text>
        <text class="bgm-name">海浪</text>
      </view>
      <view 
        class="bgm-item {{bgmSelected === 'forest' ? 'active' : ''}}"
        bindtap="selectBGM"
        data-bgm="forest"
      >
        <text class="bgm-icon">🌲</text>
        <text class="bgm-name">森林</text>
      </view>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <view 
      class="control-btn primary {{isBreathing ? 'pause' : ''}}"
      bindtap="toggleBreathing"
    >
      <text>{{isBreathing ? '⏸️ 暂停' : '▶️ 开始'}}</text>
    </view>
    <view class="control-btn secondary" bindtap="resetBreathing">
      <text>🔄 重置</text>
    </view>
  </view>

  <!-- 倒计时显示 -->
  <view class="timer-section" wx:if="{{showTimer}}">
    <text class="timer-text">{{timerDisplay}}</text>
    <text class="timer-hint">⏱️ 剩余时间</text>
    <view class="timer-controls">
      <view class="timer-btn" bindtap="addTime" data-minutes="1">
        <text>+1 分钟</text>
      </view>
      <view class="timer-btn" bindtap="addTime" data-minutes="5">
        <text>+5 分钟</text>
      </view>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="settings-section">
    <text class="section-title">⚙️ 练习设置</text>
    <view class="setting-item">
      <text class="setting-label">练习时长</text>
      <picker mode="selector" range="{{durationOptions}}" value="{{durationIndex}}" bindchange="onDurationChange">
        <text class="setting-value">{{durationOptions[durationIndex]}} ▸</text>
      </picker>
    </view>
    <view class="setting-item">
      <text class="setting-label">TTS 语音引导</text>
      <switch checked="{{ttsEnabled}}" bindchange="onTTSToggle" color="#4CAF50" />
    </view>
  </view>
</view>

<!-- 音频组件 -->
<audio
  id="bgmAudio"
  src="{{bgmSrc}}"
  loop="{{true}}"
  autoplay="{{false}}"
  bindplay="onBGMPlay"
  bindpause="onBGMPause"
  bindended="onBGMEnded"
></audio>
