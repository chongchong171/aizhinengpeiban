/**
 * 呼吸练习页面样式
 * @description 动画引导呼吸练习
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #BBDEFB 50%, #90CAF9 100%);
  padding: 40rpx 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.15);
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1976D2;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #546E7A;
}

/* 呼吸引导区域 */
.breathing-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 60rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(33, 150, 243, 0.2);
}

.breathing-circle {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #64B5F6 0%, #2196F3 50%, #1976D2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(33, 150, 243, 0.4),
              inset 0 -8rpx 24rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

/* 吸气状态 - 放大 */
.breathing-circle.inhale {
  animation: inhaleAnimation 4s ease-in-out forwards;
}

/* 屏息状态 */
.breathing-circle.hold {
  animation: holdAnimation 7s ease-in-out forwards;
}

/* 呼气状态 - 缩小 */
.breathing-circle.exhale {
  animation: exhaleAnimation 8s ease-in-out forwards;
}

@keyframes inhaleAnimation {
  0% { transform: scale(1); }
  100% { transform: scale(1.5); }
}

@keyframes holdAnimation {
  0%, 100% { transform: scale(1.5); }
}

@keyframes exhaleAnimation {
  0% { transform: scale(1.5); }
  100% { transform: scale(1); }
}

.inner-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.breath-icon {
  font-size: 60rpx;
}

.breathing-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1565C0;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.breathing-hint {
  font-size: 26rpx;
  color: #78909C;
  margin-bottom: 20rpx;
}

/* 进度指示器 */
.progress-dots {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #CFD8DC;
  transition: all 0.3s ease;
}

.dot.active {
  background-color: #2196F3;
  width: 32rpx;
  border-radius: 8rpx;
}

/* 背景音选择区域 */
.bgm-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #37474F;
  margin-bottom: 20rpx;
}

.bgm-options {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.bgm-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: rgba(242, 242, 242, 0.8);
  border-radius: 16rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.bgm-item.active {
  background-color: #E3F2FD;
  border-color: #2196F3;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.2);
}

.bgm-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.bgm-name {
  font-size: 24rpx;
  color: #546E7A;
}

.bgm-item.active .bgm-name {
  color: #1976D2;
  font-weight: 600;
}

/* 控制按钮 */
.controls {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.control-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.control-btn.primary {
  background: linear-gradient(135deg, #42A5F5 0%, #1976D2 100%);
  color: #FFFFFF;
}

.control-btn.primary.pause {
  background: linear-gradient(135deg, #FFA726 0%, #F57C00 100%);
}

.control-btn.secondary {
  background-color: rgba(255, 255, 255, 0.9);
  color: #1976D2;
  border: 2rpx solid #1976D2;
}

.control-btn:active {
  transform: scale(0.95);
}

/* 倒计时区域 */
.timer-section {
  text-align: center;
  padding: 40rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

.timer-text {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #1565C0;
  margin-bottom: 10rpx;
  font-family: 'Courier New', monospace;
}

.timer-hint {
  display: block;
  font-size: 24rpx;
  color: #78909C;
  margin-bottom: 20rpx;
}

.timer-controls {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.timer-btn {
  padding: 12rpx 24rpx;
  background-color: #E3F2FD;
  color: #1976D2;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.timer-btn:active {
  background-color: #BBDEFB;
}

/* 设置区域 */
.settings-section {
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ECEFF1;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #37474F;
  font-weight: 500;
}

.setting-value {
  font-size: 28rpx;
  color: #1976D2;
  font-weight: 500;
}
