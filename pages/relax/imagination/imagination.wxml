<!--
  想象放松页面（深呼吸一下子功能）
  @description 选择场景进行想象放松，配合背景图和背景音
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：放松引导 → 深呼吸一下
-->

<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">🌈 想象放松</text>
    <text class="subtitle">心灵之旅 · 场景冥想</text>
  </view>

  <!-- 场景选择 -->
  <view class="scene-selector" wx:if="{{!selectedScene}}">
    <text class="selector-title">选择一个放松场景</text>
    
    <view 
      class="scene-card"
      wx:for="{{scenes}}"
      wx:key="id"
      bindtap="selectScene"
      data-scene="{{item}}"
    >
      <view class="scene-image" style="background: {{item.gradient}};">
        <text class="scene-emoji">{{item.emoji}}</text>
      </view>
      <view class="scene-info">
        <text class="scene-name">{{item.name}}</text>
        <text class="scene-desc">{{item.description}}</text>
      </view>
    </view>
  </view>

  <!-- 场景体验 -->
  <view class="scene-experience" wx:if="{{selectedScene}}">
    <!-- 场景背景 -->
    <view class="scene-background" style="background: {{selectedScene.gradient}};">
      <view class="scene-content">
        <text class="scene-emoji-large">{{selectedScene.emoji}}</text>
        <text class="scene-name-large">{{selectedScene.name}}</text>
      </view>
      
      <!-- 返回按钮 -->
      <view class="back-btn" bindtap="backToSelect">
        <text>◀ 返回选择</text>
      </view>
    </view>

    <!-- 引导文字 -->
    <view class="guide-section">
      <text class="guide-title">🎧 引导词</text>
      <view class="guide-text-box">
        <text class="guide-text">{{currentGuideText}}</text>
      </view>
      
      <!-- 播放控制 -->
      <view class="guide-controls">
        <view 
          class="control-btn primary {{isPlaying ? 'pause' : ''}}"
          bindtap="toggleGuide"
        >
          <text>{{isPlaying ? '⏸️ 暂停' : '▶️ 播放引导'}}</text>
        </view>
        <view class="control-btn secondary" bindtap="replay">
          <text>🔄 重播</text>
        </view>
      </view>
    </view>

    <!-- 背景音控制 -->
    <view class="bgm-section">
      <text class="section-title">🎵 背景音</text>
      <view class="volume-control">
        <text class="volume-icon">🔊</text>
        <slider 
          value="{{volume}}" 
          bindchange="onVolumeChange"
          min="0"
          max="100"
          activeColor="{{selectedScene.color}}"
          block-size="20"
        />
      </view>
      <view class="bgm-status">
        <text>{{isBGMPlaying ? '播放中' : '已暂停'}}</text>
      </view>
    </view>

    <!-- 定时关闭 -->
    <view class="timer-section">
      <text class="section-title">⏱️ 定时关闭</text>
      <view class="timer-options">
        <view 
          class="timer-option {{timerMinutes === 10 ? 'active' : ''}}"
          style="border-color: {{timerMinutes === 10 ? selectedScene.color : '#DDD'}}"
          bindtap="setTimer"
          data-minutes="10"
        >
          <text>10 分钟</text>
        </view>
        <view 
          class="timer-option {{timerMinutes === 20 ? 'active' : ''}}"
          style="border-color: {{timerMinutes === 20 ? selectedScene.color : '#DDD'}}"
          bindtap="setTimer"
          data-minutes="20"
        >
          <text>20 分钟</text>
        </view>
        <view 
          class="timer-option {{timerMinutes === 30 ? 'active' : ''}}"
          style="border-color: {{timerMinutes === 30 ? selectedScene.color : '#DDD'}}"
          bindtap="setTimer"
          data-minutes="30"
        >
          <text>30 分钟</text>
        </view>
        <view 
          class="timer-option {{timerMinutes === 0 ? 'active' : ''}}"
          style="border-color: {{timerMinutes === 0 ? '#FF5722' : '#DDD'}}"
          bindtap="setTimer"
          data-minutes="0"
        >
          <text>关闭</text>
        </view>
      </view>
      
      <!-- 倒计时显示 -->
      <view class="timer-display" wx:if="{{showTimer}}">
        <text class="timer-text">{{timerDisplay}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 音频组件 -->
<audio
  id="bgmAudio"
  src="{{bgmSrc}}"
  loop="{{true}}"
  autoplay="{{false}}"
  bindplay="onBGMPlay"
  bindpause="onBGMPause"
></audio>
