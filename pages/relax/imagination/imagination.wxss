/**
 * 想象放松页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF3E0 0%, #FFE0B2 50%, #FFCC80 100%);
  padding: 40rpx 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.15);
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #E65100;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #F57C00;
}

/* 场景选择 */
.scene-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.selector-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  text-align: center;
}

.scene-card {
  display: flex;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.scene-card:active {
  transform: scale(0.98);
}

.scene-image {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.scene-emoji {
  font-size: 80rpx;
}

.scene-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx;
}

.scene-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.scene-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 场景体验 */
.scene-experience {
  display: flex;
  flex-direction: column;
}

.scene-background {
  width: 100%;
  height: 500rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.scene-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.scene-emoji-large {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.scene-name-large {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.back-btn {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  padding: 16rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #333;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 引导区域 */
.guide-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
}

.guide-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.guide-text-box {
  padding: 24rpx;
  background-color: rgba(255, 243, 224, 0.5);
  border-radius: 16rpx;
  border-left: 6rpx solid #FF9800;
  margin-bottom: 20rpx;
}

.guide-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.guide-controls {
  display: flex;
  gap: 20rpx;
}

.control-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.control-btn.primary {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  color: #FFFFFF;
}

.control-btn.pause {
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
}

.control-btn.secondary {
  background-color: rgba(255, 255, 255, 0.9);
  color: #FF9800;
  border: 2rpx solid #FF9800;
}

/* 背景音区域 */
.bgm-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.volume-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.volume-icon {
  font-size: 32rpx;
}

.bgm-status {
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

/* 定时关闭区域 */
.timer-section {
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
}

.timer-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.timer-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background-color: #FFFFFF;
  border: 2rpx solid #DDD;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  transition: all 0.3s ease;
}

.timer-option.active {
  background-color: rgba(255, 152, 0, 0.1);
  font-weight: 600;
  color: #E65100;
}

.timer-display {
  text-align: center;
  padding: 20rpx;
  background-color: rgba(255, 243, 224, 0.5);
  border-radius: 16rpx;
}

.timer-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #E65100;
  font-family: 'Courier New', monospace;
}
