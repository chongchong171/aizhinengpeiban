<!--
  深呼吸一下页面（原放松引导）
  @description 放松练习导航页
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：放松引导 → 深呼吸一下
-->

<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <!-- 【女性审美优化】放松引导 → 深呼吸一下 -->
    <text class="title">🧘 深呼吸一下</text>
    <text class="subtitle">选择一种放松方式，舒缓身心</text>
  </view>

  <!-- 功能入口 -->
  <view class="feature-grid">
    <view 
      class="feature-card breath"
      bindtap="navigateTo"
      data-page="/pages/relax/breath/breath"
    >
      <view class="feature-icon">🌬️</view>
      <text class="feature-name">呼吸练习</text>
      <text class="feature-desc">4-7-8 呼吸法 · 配合动画和背景音</text>
    </view>
    
    <view 
      class="feature-card body-scan"
      bindtap="navigateTo"
      data-page="/pages/relax/body-scan/body-scan"
    >
      <view class="feature-icon">💆</view>
      <text class="feature-name">身体扫描</text>
      <text class="feature-desc">渐进式放松 · TTS 语音引导</text>
    </view>
    
    <view 
      class="feature-card imagination"
      bindtap="navigateTo"
      data-page="/pages/relax/imagination/imagination"
    >
      <view class="feature-icon">🌈</view>
      <text class="feature-name">想象放松</text>
      <text class="feature-desc">场景冥想 · 海滩/森林/云端</text>
    </view>
    
    <view 
      class="feature-card quick"
      bindtap="navigateTo"
      data-page="/pages/relax/quick/quick"
    >
      <view class="feature-icon">⚡</view>
      <text class="feature-name">快速放松</text>
      <text class="feature-desc">1 分钟应急 · 快速深呼吸</text>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="tips-section">
    <text class="tips-title">💡 使用建议</text>
    <view class="tips-list">
      <text class="tip-item">• 呼吸练习：适合日常放松，缓解焦虑</text>
      <text class="tip-item">• 身体扫描：适合睡前放松，释放身体紧张</text>
      <text class="tip-item">• 想象放松：适合压力大的时候，心灵之旅</text>
      <text class="tip-item">• 快速放松：适合应急使用，快速平静</text>
    </view>
  </view>
</view>
