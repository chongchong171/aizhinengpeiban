<!--
  快速放松页面（深呼吸一下子功能）
  @description 1 分钟应急快速放松，简单深呼吸
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：放松引导 → 深呼吸一下
-->

<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">⚡ 快速放松</text>
    <text class="subtitle">1 分钟应急放松 · 快速深呼吸</text>
  </view>

  <!-- 倒计时主显示 -->
  <view class="countdown-main">
    <text class="countdown-text">{{countdownDisplay}}</text>
    <text class="countdown-label">秒</text>
  </view>

  <!-- 呼吸动画 -->
  <view class="quick-breath">
    <view class="breath-circle {{breathState}}">
      <view class="breath-icon">{{breathIcon}}</view>
    </view>
    <text class="breath-instruction">{{breathInstruction}}</text>
  </view>

  <!-- 进度环 -->
  <view class="progress-ring-container">
    <svg class="progress-ring" width="200" height="200">
      <circle
        class="progress-ring-circle-bg"
        stroke="#E0E0E0"
        stroke-width="8"
        fill="transparent"
        r="90"
        cx="100"
        cy="100"
      />
      <circle
        class="progress-ring-circle"
        stroke="{{progressColor}}"
        stroke-width="8"
        fill="transparent"
        r="90"
        cx="100"
        cy="100"
        style="stroke-dashoffset: {{strokeDashoffset}};"
      />
    </svg>
    <text class="progress-text">{{progress}}%</text>
  </view>

  <!-- 呼吸引导 -->
  <view class="guide-steps">
    <view class="step {{currentStep >= 1 ? 'active' : ''}}">
      <text class="step-num">1</text>
      <text class="step-text">深吸气 4 秒</text>
    </view>
    <view class="step-arrow">→</view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}}">
      <text class="step-num">2</text>
      <text class="step-text">屏息 2 秒</text>
    </view>
    <view class="step-arrow">→</view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <text class="step-num">3</text>
      <text class="step-text">缓呼气 4 秒</text>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <view 
      class="control-btn primary {{isRunning ? 'pause' : ''}}"
      bindtap="toggleStart"
    >
      <text>{{isRunning ? '⏸️ 暂停' : '▶️ 开始'}}</text>
    </view>
    <view class="control-btn secondary" bindtap="reset">
      <text>🔄 重置</text>
    </view>
  </view>

  <!-- 提示文字 -->
  <view class="tips-section">
    <text class="tips-title">💡 快速放松小贴士</text>
    <view class="tips-list">
      <text class="tip-item">• 感到紧张时立即使用</text>
      <text class="tip-item">• 配合深呼吸效果更好</text>
      <text class="tip-item">• 每天可多次练习</text>
      <text class="tip-item">• 帮助快速缓解焦虑</text>
    </view>
  </view>

  <!-- 完成动画 -->
  <view class="complete-overlay" wx:if="{{showComplete}}">
    <view class="complete-content">
      <text class="complete-emoji">🎉</text>
      <text class="complete-text">完成！</text>
      <text class="complete-sub">感觉放松些了吗？</text>
      <view class="complete-btn" bindtap="closeComplete">
        <text>好的</text>
      </view>
    </view>
  </view>
</view>
