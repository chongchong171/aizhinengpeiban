/**
 * 快速放松页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFEBEE 0%, #FFCDD2 50%, #EF9A9A 100%);
  padding: 40rpx 30rpx;
  position: relative;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(244, 67, 54, 0.15);
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #C62828;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #D32F2F;
}

/* 倒计时主显示 */
.countdown-main {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 235, 238, 0.95) 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(244, 67, 54, 0.2);
}

.countdown-text {
  display: block;
  font-size: 120rpx;
  font-weight: 700;
  color: #C62828;
  font-family: 'Courier New', monospace;
  line-height: 1;
}

.countdown-label {
  display: block;
  font-size: 28rpx;
  color: #D32F2F;
  margin-top: 10rpx;
}

/* 呼吸动画 */
.quick-breath {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.breath-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EF5350 0%, #E53935 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(229, 57, 53, 0.4);
  transition: transform 0.3s ease;
}

.breath-circle.inhale {
  animation: quickInhale 4s ease-in-out forwards;
}

.breath-circle.hold {
  animation: quickHold 2s ease-in-out forwards;
}

.breath-circle.exhale {
  animation: quickExhale 4s ease-in-out forwards;
}

@keyframes quickInhale {
  0% { transform: scale(1); }
  100% { transform: scale(1.4); }
}

@keyframes quickHold {
  0%, 100% { transform: scale(1.4); }
}

@keyframes quickExhale {
  0% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

.breath-icon {
  font-size: 80rpx;
}

.breath-instruction {
  font-size: 32rpx;
  font-weight: 600;
  color: #C62828;
  text-align: center;
}

/* 进度环 */
.progress-ring-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 30rpx auto;
}

.progress-ring {
  transform: rotate(-90deg);
  transform-origin: 50% 50%;
}

.progress-ring-circle-bg {
  stroke: #E0E0E0;
}

.progress-ring-circle {
  stroke-linecap: round;
  stroke-dasharray: 565;
  stroke-dashoffset: 565;
  transition: stroke-dashoffset 0.3s ease;
}

.progress-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  font-weight: 700;
  color: #C62828;
}

/* 引导步骤 */
.guide-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-num {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #FFCDD2;
  color: #C62828;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.step.active .step-num {
  background-color: #E53935;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.4);
}

.step-text {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.step.active .step-text {
  color: #C62828;
  font-weight: 600;
}

.step-arrow {
  font-size: 32rpx;
  color: #FFCDD2;
  margin: 0 10rpx;
}

/* 控制按钮 */
.controls {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.control-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.control-btn.primary {
  background: linear-gradient(135deg, #EF5350 0%, #E53935 100%);
  color: #FFFFFF;
}

.control-btn.primary.pause {
  background: linear-gradient(135deg, #FF8A65 0%, #FF7043 100%);
}

.control-btn.secondary {
  background-color: rgba(255, 255, 255, 0.9);
  color: #E53935;
  border: 2rpx solid #E53935;
}

.control-btn:active {
  transform: scale(0.95);
}

/* 提示区域 */
.tips-section {
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 完成动画 */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.complete-content {
  width: 600rpx;
  padding: 60rpx 40rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.complete-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  animation: bounce 0.6s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.complete-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #E53935;
  margin-bottom: 16rpx;
}

.complete-sub {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.complete-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #EF5350 0%, #E53935 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.3);
}
