/**
 * 身体扫描页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F3E5F5 0%, #E1BEE7 50%, #CE93D8 100%);
  padding: 40rpx 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(156, 39, 176, 0.15);
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #7B1FA2;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #6A1B9A;
}

/* 当前放松部位 */
.current-part {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 50rpx 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(243, 229, 245, 0.9) 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(156, 39, 176, 0.2);
}

.body-diagram {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #BA68C8 0%, #8E24AA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(142, 36, 170, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.part-icon {
  font-size: 80rpx;
}

.part-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #6A1B9A;
  margin-bottom: 16rpx;
}

.part-instruction {
  font-size: 28rpx;
  color: #8E24AA;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #E1BEE7;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #BA68C8 0%, #8E24AA 100%);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #AB47BC;
}

/* 部位列表 */
.parts-list {
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 20rpx;
}

.part-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 12rpx;
  background-color: rgba(243, 229, 245, 0.5);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.part-item:last-child {
  margin-bottom: 0;
}

.part-item.active {
  background-color: #E1BEE7;
  box-shadow: 0 4rpx 12rpx rgba(156, 39, 176, 0.2);
  transform: scale(1.02);
}

.part-item.completed {
  background-color: rgba(186, 104, 200, 0.2);
}

.part-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #CE93D8;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.part-item.active .part-number {
  background-color: #8E24AA;
}

.part-item.completed .part-number {
  background-color: #4CAF50;
}

.part-text {
  flex: 1;
  font-size: 28rpx;
  color: #4A148C;
  font-weight: 500;
}

.part-item.completed .part-text {
  color: #9E9E9E;
  text-decoration: line-through;
}

.part-status {
  font-size: 32rpx;
  color: #8E24AA;
  margin-left: 16rpx;
}

/* 控制按钮 */
.controls {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.control-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.control-btn.primary {
  background: linear-gradient(135deg, #AB47BC 0%, #7B1FA2 100%);
  color: #FFFFFF;
}

.control-btn.primary.pause {
  background: linear-gradient(135deg, #FFA726 0%, #F57C00 100%);
}

.control-btn.secondary {
  background-color: rgba(255, 255, 255, 0.9);
  color: #7B1FA2;
  border: 2rpx solid #7B1FA2;
}

.control-btn:active {
  transform: scale(0.95);
}

/* 设置区域 */
.settings-section {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4A148C;
  margin-bottom: 20rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E1BEE7;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #4A148C;
  font-weight: 500;
}

.setting-value {
  font-size: 28rpx;
  color: #8E24AA;
  font-weight: 500;
}

/* 倒计时区域 */
.timer-section {
  text-align: center;
  padding: 40rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
}

.timer-text {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #6A1B9A;
  margin-bottom: 10rpx;
  font-family: 'Courier New', monospace;
}

.timer-hint {
  display: block;
  font-size: 24rpx;
  color: #8E24AA;
}
