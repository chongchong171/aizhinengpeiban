<!--
  身体扫描页面（深呼吸一下子功能）
  @description TTS 引导放松身体各部位，配合轻柔音乐
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：放松引导 → 深呼吸一下
-->

<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">💆 身体扫描</text>
    <text class="subtitle">渐进式肌肉放松法</text>
  </view>

  <!-- 当前放松部位 -->
  <view class="current-part">
    <view class="body-diagram">
      <text class="part-icon">{{currentPartIcon}}</text>
    </view>
    <text class="part-name">{{currentPartName}}</text>
    <text class="part-instruction">{{currentInstruction}}</text>
    
    <!-- 进度条 -->
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
    <text class="progress-text">{{currentPartIndex + 1}} / {{bodyParts.length}}</text>
  </view>

  <!-- 身体部位列表 -->
  <view class="parts-list">
    <view 
      class="part-item {{index === currentPartIndex ? 'active' : ''}} {{index < currentPartIndex ? 'completed' : ''}}"
      wx:for="{{bodyParts}}"
      wx:key="name"
      bindtap="jumpToPart"
      data-index="{{index}}"
    >
      <text class="part-number">{{index + 1}}</text>
      <text class="part-text">{{item.name}}</text>
      <text class="part-status">{{index < currentPartIndex ? '✓' : (index === currentPartIndex ? '▶' : '')}}</text>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <view 
      class="control-btn primary {{isPlaying ? 'pause' : ''}}"
      bindtap="togglePlay"
    >
      <text>{{isPlaying ? '⏸️ 暂停' : '▶️ 开始'}}</text>
    </view>
    <view class="control-btn secondary" bindtap="reset">
      <text>🔄 重置</text>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="settings-section">
    <text class="section-title">⚙️ 练习设置</text>
    
    <view class="setting-item">
      <text class="setting-label">背景音乐</text>
      <switch checked="{{bgmEnabled}}" bindchange="onBGMToggle" color="#9C27B0" />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">TTS 语音引导</text>
      <switch checked="{{ttsEnabled}}" bindchange="onTTSToggle" color="#9C27B0" />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">定时关闭</text>
      <picker mode="selector" range="{{timerOptions}}" value="{{timerIndex}}" bindchange="onTimerChange">
        <text class="setting-value">{{timerOptions[timerIndex]}} ▸</text>
      </picker>
    </view>
  </view>

  <!-- 倒计时显示 -->
  <view class="timer-section" wx:if="{{showTimer}}">
    <text class="timer-text">{{timerDisplay}}</text>
    <text class="timer-hint">⏱️ 剩余时间</text>
  </view>
</view>

<!-- 音频组件 -->
<audio
  id="bgmAudio"
  src="/audio/relax_music.mp3"
  loop="{{true}}"
  autoplay="{{false}}"
></audio>
