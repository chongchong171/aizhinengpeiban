/**
 * 放松引导页面样式 - 主入口
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F5F5 0%, #E8E8E8 100%);
  padding: 40rpx 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 功能网格 */
.feature-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.feature-card:active {
  transform: scale(0.98);
}

/* 功能卡片颜色主题 */
.feature-card.breath {
  border-top: 6rpx solid #2196F3;
}

.feature-card.breath .feature-icon {
  background: linear-gradient(135deg, #64B5F6 0%, #2196F3 100%);
}

.feature-card.body-scan {
  border-top: 6rpx solid #9C27B0;
}

.feature-card.body-scan .feature-icon {
  background: linear-gradient(135deg, #BA68C8 0%, #9C27B0 100%);
}

.feature-card.imagination {
  border-top: 6rpx solid #FF9800;
}

.feature-card.imagination .feature-icon {
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
}

.feature-card.quick {
  border-top: 6rpx solid #E53935;
}

.feature-card.quick .feature-icon {
  background: linear-gradient(135deg, #EF5350 0%, #E53935 100%);
}

.feature-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.feature-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
}

/* 使用说明 */
.tips-section {
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
