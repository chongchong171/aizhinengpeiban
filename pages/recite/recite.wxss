/**
 * 朗读功能页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
}

/* 录音器区域 */
.recorder-section {
  margin-bottom: 30rpx;
}

.recorder-card {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  border-radius: 32rpx;
  padding: 60rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recorder-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.wave-animation {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  height: 60rpx;
}

.wave-bar {
  width: 8rpx;
  height: 40rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 4rpx;
  animation: wave 0.5s ease-in-out infinite;
}

.wave-bar:nth-child(1) { animation-delay: 0s; }
.wave-bar:nth-child(2) { animation-delay: 0.1s; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; }
.wave-bar:nth-child(4) { animation-delay: 0.3s; }
.wave-bar:nth-child(5) { animation-delay: 0.4s; }

@keyframes wave {
  0%, 100% { height: 20rpx; }
  50% { height: 60rpx; }
}

.status-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.status-time {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  font-family: monospace;
}

.recorder-controls {
  display: flex;
  justify-content: center;
}

.record-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s;
}

.record-btn:active {
  transform: scale(0.95);
}

.record-btn.recording {
  background-color: #fff;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.record-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.record-text {
  font-size: 26rpx;
  color: #FF6B81;
  font-weight: 600;
}

/* 内容选择区域 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.content-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.content-card {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.1);
  transition: all 0.2s;
}

.content-card:active {
  transform: scale(0.95);
  background-color: rgba(255, 107, 129, 0.1);
}

.content-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.content-name {
  font-size: 24rpx;
  color: #333;
}

/* 文本卡片 */
.text-card {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.1);
}

.text-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

/* 录音列表 */
.recordings-list {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 20rpx;
}

.recording-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(255, 107, 129, 0.1);
}

.recording-item:last-child {
  border-bottom: none;
}

.recording-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.recording-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.recording-details {
  display: flex;
  flex-direction: column;
}

.recording-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.recording-date {
  font-size: 24rpx;
  color: #999;
}

.recording-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(255, 107, 129, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  border: none;
  font-size: 28rpx;
}

.action-btn.delete {
  background-color: rgba(255, 100, 100, 0.1);
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
