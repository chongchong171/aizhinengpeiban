<!--
  朗读功能页面
  @description 用户自己朗读，录音功能
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：功能名称统一
-->

<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="page-title">📢 朗读功能</text>
    <text class="page-desc">用你的声音记录美好</text>
  </view>

  <!-- 录音控制区域 -->
  <view class="recorder-section">
    <view class="recorder-card">
      <!-- 录音状态 -->
      <view class="recorder-status">
        <view class="wave-animation" wx:if="{{isRecording}}">
          <view class="wave-bar"></view>
          <view class="wave-bar"></view>
          <view class="wave-bar"></view>
          <view class="wave-bar"></view>
          <view class="wave-bar"></view>
        </view>
        <text class="status-emoji">{{isRecording ? '🎤' : '🎧'}}</text>
        <text class="status-text">{{isRecording ? '正在录音...' : '准备录音'}}</text>
        <text class="status-time">{{recordingTime}}</text>
      </view>

      <!-- 录音控制按钮 -->
      <view class="recorder-controls">
        <button 
          class="record-btn {{isRecording ? 'recording' : ''}}" 
          bindtap="toggleRecording"
          bindlongpress="startRecording"
          bindtouchend="stopRecording"
        >
          <text class="record-icon">{{isRecording ? '⏹️' : '🎤'}}</text>
          <text class="record-text">{{isRecording ? '停止' : '长按录音'}}</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 朗读内容选择 -->
  <view class="section">
    <view class="section-title">选择朗读内容</view>
    <view class="content-grid">
      <view class="content-card" bindtap="selectContent" data-type="poem">
        <text class="content-icon">📜</text>
        <text class="content-name">诗歌</text>
      </view>
      <view class="content-card" bindtap="selectContent" data-type="story">
        <text class="content-icon">📖</text>
        <text class="content-name">故事</text>
      </view>
      <view class="content-card" bindtap="selectContent" data-type="article">
        <text class="content-icon">📰</text>
        <text class="content-name">文章</text>
      </view>
      <view class="content-card" bindtap="selectContent" data-type="custom">
        <text class="content-icon">✏️</text>
        <text class="content-name">自定义</text>
      </view>
    </view>
  </view>

  <!-- 当前朗读内容 -->
  <view class="section" wx:if="{{currentText}}">
    <view class="section-title">朗读内容</view>
    <view class="text-card">
      <text class="text-content">{{currentText}}</text>
    </view>
  </view>

  <!-- 录音列表 -->
  <view class="section">
    <view class="section-title">我的录音</view>
    <view class="recordings-list">
      <view class="recording-item" wx:for="{{recordings}}" wx:key="id">
        <view class="recording-info">
          <text class="recording-icon">🎵</text>
          <view class="recording-details">
            <text class="recording-title">{{item.title}}</text>
            <text class="recording-date">{{item.date}}</text>
          </view>
        </view>
        <view class="recording-actions">
          <button class="action-btn" bindtap="playRecording" data-id="{{item.id}}">
            <text>▶️</text>
          </button>
          <button class="action-btn delete" bindtap="deleteRecording" data-id="{{item.id}}">
            <text>🗑️</text>
          </button>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{recordings.length === 0}}">
        <text>还没有录音哦~</text>
      </view>
    </view>
  </view>
</view>
