/**
 * 首页样式 - 优化版 v2.0
 * @date 2026-03-16
 * @update 功能优先级优化，场景化入口，分类展示
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  padding: 0 0 60rpx;
  position: relative;
}

/* ========== 顶部装饰区域 ========== */
.header-decoration {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  padding: 32rpx 32rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-time {
  display: flex;
  flex-direction: column;
}

.date-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.time-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.user-level {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.level-text {
  font-size: 24rpx;
  color: #FFF;
  font-weight: bold;
}

.level-stars {
  font-size: 24rpx;
}

/* 标题区域 */
.title-section {
  text-align: center;
  padding: 12rpx 0 8rpx;
}

.main-title {
  display: block;
  font-size: 42rpx;
  font-weight: bold;
  color: #FFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.sub-title {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
}

/* ========== 树洞形象区域 ========== */
.tree-hole-section {
  background: linear-gradient(135deg, rgba(255, 107, 129, 0.08) 0%, rgba(255, 143, 163, 0.08) 100%);
  border: 2rpx solid rgba(255, 107, 129, 0.2);
  margin: 24rpx 24rpx 20rpx;
  border-radius: 24rpx;
  padding: 24rpx 28rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.15);
  position: relative;
  overflow: hidden;
}

/* 顶部状态栏 */
.tree-hole-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-icon {
  font-size: 28rpx;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

.tree-hole-image {
  text-align: center;
  margin-bottom: 20rpx;
  position: relative;
}

.tree-hole-illustration {
  width: 220rpx;
  height: 220rpx;
}

/* 漂浮装饰 */
.floating-decoration {
  position: absolute;
  font-size: 36rpx;
  animation: float 3s ease-in-out infinite;
  opacity: 0.7;
}

.dec-1 { top: 20rpx; left: 40rpx; animation-delay: 0s; }
.dec-2 { top: 40rpx; right: 60rpx; animation-delay: 0.5s; }
.dec-3 { bottom: 60rpx; left: 60rpx; animation-delay: 1s; }
.dec-4 { bottom: 40rpx; right: 40rpx; animation-delay: 1.5s; }
.dec-5 { top: 50%; left: 20rpx; animation-delay: 2s; }

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

/* 呼吸灯效果 */
.tree-hole-section::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 107, 129, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: breathe 2s ease-in-out infinite;
  z-index: 0;
}

@keyframes breathe {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.8; }
}

.tree-hole-description {
  text-align: center;
  position: relative;
  z-index: 1;
}

.description-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-bottom: 16rpx;
}

.description-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 2;
}

.description-text.highlight {
  color: #FF6B81;
  font-weight: 600;
}

/* 互动按钮组 */
.interaction-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin: 20rpx 0 16rpx;
}

.interaction-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: #FFF;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.15);
  transition: all 0.3s;
}

.interaction-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 129, 0.2);
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

/* 底部提示 */
.interaction-hint-row {
  text-align: center;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(255, 107, 129, 0.2);
}

.interaction-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  font-style: italic;
}

/* ========== 女生宿舍专区 ========== */
.dormitory-section {
  margin: 32rpx 24rpx 24rpx;
}

.dormitory-card {
  background: linear-gradient(135deg, rgba(255, 107, 129, 0.12) 0%, rgba(255, 143, 163, 0.12) 100%);
  border: 2rpx solid rgba(255, 107, 129, 0.3);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 129, 0.2);
  transition: all 0.3s;
}

.dormitory-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.25);
}

.dormitory-icon {
  font-size: 64rpx;
  flex-shrink: 0;
}

.dormitory-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dormitory-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dormitory-desc {
  font-size: 24rpx;
  color: #999;
}

.dormitory-arrow {
  font-size: 40rpx;
  color: #CCC;
}

/* ========== 常用功能 ========== */
.quick-actions-section {
  margin: 32rpx 24rpx 24rpx;
}

.section-title-with-hint {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.section-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.quick-actions-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-action-card {
  background: #FFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.1);
  transition: all 0.3s;
}

.quick-action-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 129, 0.15);
}

.action-icon {
  font-size: 52rpx;
  flex-shrink: 0;
}

.action-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.action-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
}

/* ========== 主打功能区域 ========== */
.featured-section {
  margin: 32rpx 24rpx 24rpx;
}

.featured-card {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.35);
  transition: all 0.3s;
}

.featured-card:active {
  transform: scale(0.98);
}

.featured-icon {
  font-size: 68rpx;
  flex-shrink: 0;
}

.featured-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.featured-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFF;
}

.featured-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.featured-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 其他功能区域 ========== */
.other-section {
  margin: 32rpx 24rpx 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #FF6B81;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.function-card {
  background: #FFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.1);
  transition: all 0.3s;
}

.function-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 129, 0.15);
}

.function-card.highlight-card {
  background: linear-gradient(135deg, rgba(255, 107, 129, 0.08) 0%, rgba(255, 143, 163, 0.08) 100%);
  border: 2rpx solid rgba(255, 107, 129, 0.25);
}

.function-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.function-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
}

.function-desc {
  font-size: 20rpx;
  color: #999;
  line-height: 1.4;
  text-align: center;
  margin-top: 4rpx;
}

/* ========== 个人中心 ========== */
.profile-section {
  margin: 32rpx 24rpx 24rpx;
}

.profile-card {
  background: #FFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.profile-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.profile-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.profile-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.profile-desc {
  font-size: 24rpx;
  color: #999;
}

.profile-arrow {
  font-size: 40rpx;
  color: #CCC;
}

/* ========== 🌟 商业化功能（福利中心） ========== */
.commercial-section {
  margin: 32rpx 24rpx 24rpx;
}

.commercial-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 4rpx;
}

.commercial-card {
  background: linear-gradient(135deg, #FFF 0%, #FFF9FA 100%);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 129, 0.12);
  transition: all 0.3s;
  border: 2rpx solid rgba(255, 107, 129, 0.08);
}

.commercial-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.18);
  border-color: rgba(255, 107, 129, 0.2);
}

.commercial-icon {
  font-size: 64rpx;
  flex-shrink: 0;
}

.commercial-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  width: 100%;
}

.commercial-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
}

.commercial-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.4;
}

/* ========== 🏠 宿舍装修商城 ========== */
.decoration-section {
  margin: 32rpx 24rpx 24rpx;
}

.decoration-card {
  background: linear-gradient(135deg, #FFF 0%, #FFF5F8 100%);
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 129, 0.12);
  transition: all 0.3s;
  border: 2rpx solid rgba(255, 107, 129, 0.1);
}

.decoration-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.16);
  border-color: rgba(255, 107, 129, 0.18);
}

.decoration-icon {
  font-size: 64rpx;
  flex-shrink: 0;
}

.decoration-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.decoration-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.decoration-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.decoration-arrow {
  font-size: 40rpx;
  color: #CCC;
  flex-shrink: 0;
}

/* ========== 底部鼓励语 ========== */
.footer-message {
  margin: 40rpx 24rpx 24rpx;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 107, 129, 0.08) 0%, rgba(255, 143, 163, 0.08) 100%);
  border-radius: 20rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.footer-icon {
  font-size: 40rpx;
}

.daily-quote {
  display: block;
  font-size: 26rpx;
  color: #FF6B81;
  line-height: 1.8;
  font-style: italic;
}
