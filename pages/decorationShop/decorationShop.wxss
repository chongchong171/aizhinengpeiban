/* pages/decorationShop/decorationShop.wxss */
/* 装饰商城页面 - 温暖治愈系粉色系风格 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E9 100%);
}

/* 顶部积分信息 */
.points-header {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.points-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.points-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.points-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF69B4;
}

/* 分类标签 */
.category-tabs {
  background: #FFF;
  border-bottom: 2rpx solid #FFB6C1;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-wrapper {
  display: flex;
  padding: 20rpx 30rpx;
}

.category-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 20rpx;
  background: #FFF5F7;
  transition: all 0.3s;
  flex-shrink: 0;
}

.category-tab.active {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.4);
  transform: translateY(-4rpx);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.category-tab.active .tab-name {
  color: #FFF;
}

/* 商品列表 */
.products-section {
  flex: 1;
  padding: 30rpx;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.product-card {
  background: #FFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.product-card:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4E9 100%);
  display: flex;
  justify-content: center;
  align-items: center;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  object-fit: contain;
}

.new-badge,
.hot-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #FFF;
}

.new-badge {
  background: linear-gradient(135deg, #98FB98 0%, #90EE90 100%);
}

.hot-badge {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
}

.product-info {
  padding: 24rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.product-type,
.product-level {
  font-size: 22rpx;
  color: #999;
  background: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
  justify-content: center;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4E9 100%);
  padding: 16rpx;
  border-radius: 20rpx;
}

.price-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.modal-content {
  background: #FFF;
  border-radius: 30rpx;
  width: 90%;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-bottom: 2rpx solid #FF69B4;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFF;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.modal-close {
  font-size: 40rpx;
  color: #FFF;
  padding: 10rpx;
  line-height: 1;
}

/* 商品详情 */
.product-modal {
  max-height: 70vh;
}

.product-detail {
  padding: 40rpx 30rpx;
}

.detail-image {
  width: 100%;
  height: 300rpx;
  object-fit: contain;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4E9 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.detail-info {
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-description {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.detail-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  background: #FFF5F7;
  padding: 24rpx;
  border-radius: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF69B4;
}

.detail-price {
  display: flex;
  align-items: baseline;
  justify-content: center;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  padding: 24rpx;
  border-radius: 30rpx;
}

.detail-price .price-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.detail-price .price-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFF;
  margin-right: 16rpx;
}

.detail-price .price-label {
  font-size: 28rpx;
  color: #FFF;
}

.detail-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  border-top: 2rpx solid #F5F5F5;
}

.action-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s;
}

.action-btn:active {
  transform: scale(0.95);
}

.cancel-btn {
  background: linear-gradient(135deg, #FFA07A 0%, #FF8C69 100%);
  color: #FFF;
  border: none;
}

.buy-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFF;
  border: none;
}

.buy-btn[disabled] {
  background: linear-gradient(135deg, #D3D3D3 0%, #C0C0C0 100%);
  color: #999;
}

/* 购买成功提示 */
.success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 3000;
}

.success-content {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  padding: 60rpx 80rpx;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  animation: successPop 0.4s ease-out;
}

@keyframes successPop {
  from {
    transform: scale(0.5);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.success-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFF;
  margin-bottom: 16rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.success-message {
  font-size: 28rpx;
  color: #FFF;
  margin-bottom: 40rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.confirm-btn {
  background: linear-gradient(135deg, #FFF 0%, #FFF8DC 100%);
  color: #FF69B4;
  border: none;
  padding: 24rpx 80rpx;
}
