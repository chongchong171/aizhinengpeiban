<!--pages/decorationShop/decorationShop.wxml-->
<!-- 装饰商城页面 -->

<view class="container">
  <!-- 顶部积分信息 -->
  <view class="points-header">
    <view class="points-card">
      <text class="points-icon">🌟</text>
      <view class="points-info">
        <text class="points-label">星光值</text>
        <text class="points-value">{{userPoints.starlight}}</text>
      </view>
    </view>
    <view class="points-card">
      <text class="points-icon">💎</text>
      <view class="points-info">
        <text class="points-label">晶钻</text>
        <text class="points-value">{{userPoints.crystal}}</text>
      </view>
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="category-tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view class="tabs-wrapper">
        <block wx:for="{{categories}}" wx:key="id">
          <view 
            class="category-tab {{activeCategory === item.id ? 'active' : ''}}"
            bindtap="switchCategory"
            data-id="{{item.id}}"
          >
            <text class="tab-icon">{{item.icon}}</text>
            <text class="tab-name">{{item.name}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- 商品列表 -->
  <view class="products-section">
    <view class="products-grid">
      <block wx:for="{{currentProducts}}" wx:key="id">
        <view class="product-card" bindtap="onProductTap" data-id="{{item.id}}">
          <view class="product-image-wrapper">
            <image class="product-image" src="{{item.icon}}" mode="aspectFit"></image>
            <view wx:if="{{item.isNew}}" class="new-badge">NEW</view>
            <view wx:if="{{item.isHot}}" class="hot-badge">HOT</view>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <view class="product-meta">
              <text class="product-type">{{item.typeName}}</text>
              <text class="product-level">Lv.{{item.level}}</text>
            </view>
            <view class="product-price">
              <text class="price-icon">{{item.currency === 'starlight' ? '🌟' : '💎'}}</text>
              <text class="price-value">{{item.price}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 商品详情弹窗 -->
  <view wx:if="{{showProductDetail}}" class="modal-overlay" bindtap="closeProductDetail">
    <view class="modal-content product-modal" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">商品详情</text>
        <text class="modal-close" bindtap="closeProductDetail">✕</text>
      </view>
      
      <view class="product-detail">
        <image class="detail-image" src="{{selectedProduct.icon}}" mode="aspectFit"></image>
        <view class="detail-info">
          <text class="detail-name">{{selectedProduct.name}}</text>
          <text class="detail-description">{{selectedProduct.description}}</text>
          <view class="detail-stats">
            <view class="stat-item">
              <text class="stat-label">类型</text>
              <text class="stat-value">{{selectedProduct.typeName}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">等级</text>
              <text class="stat-value">Lv.{{selectedProduct.level}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-label">评分加成</text>
              <text class="stat-value">+{{selectedProduct.scoreBonus}}</text>
            </view>
          </view>
          <view class="detail-price">
            <text class="price-icon">{{selectedProduct.currency === 'starlight' ? '🌟' : '💎'}}</text>
            <text class="price-value">{{selectedProduct.price}}</text>
            <text class="price-label">{{selectedProduct.currency === 'starlight' ? '星光值' : '晶钻'}}</text>
          </view>
        </view>
      </view>
      
      <view class="detail-actions">
        <button class="action-btn cancel-btn" bindtap="closeProductDetail">再看看</button>
        <button 
          class="action-btn buy-btn" 
          bindtap="confirmBuy"
          disabled="{{!canAfford}}"
        >
          {{canAfford ? '立即购买' : '积分不足'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 购买成功提示 -->
  <view wx:if="{{showBuySuccess}}" class="success-overlay" bindtap="closeBuySuccess">
    <view class="success-content" catchtap="true">
      <text class="success-icon">🎉</text>
      <text class="success-title">购买成功！</text>
      <text class="success-message">您已获得 {{selectedProduct.name}}</text>
      <button class="action-btn confirm-btn" bindtap="closeBuySuccess">太好了</button>
    </view>
  </view>
</view>
