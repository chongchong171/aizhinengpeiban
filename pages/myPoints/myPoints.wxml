<!--我的积分页面-->
<view class="container">
  <!-- 积分总览 -->
  <view class="points-overview">
    <view class="points-card starlight">
      <view class="points-icon">🌟</view>
      <view class="points-info">
        <text class="points-value">{{points.starlight}}</text>
        <text class="points-label">星光值</text>
        <text class="points-desc">累计获得 {{points.totalStarlight}}</text>
      </view>
    </view>
    
    <view class="points-card crystal">
      <view class="points-icon">💎</view>
      <view class="points-info">
        <text class="points-value">{{points.crystal}}</text>
        <text class="points-label">晶钻</text>
        <text class="points-desc">累计获得 {{points.totalCrystal}}</text>
      </view>
    </view>
  </view>

  <!-- 等级信息 -->
  <view class="level-section">
    <view class="section-title">我的等级</view>
    <view class="level-card">
      <view class="level-info">
        <text class="level-badge">Lv.{{level}}</text>
        <text class="level-exp">经验值 {{exp}} / {{nextLevelExp}}</text>
      </view>
      <view class="level-progress">
        <view class="progress-bar" style="width: {{expPercent}}%"></view>
      </view>
      <text class="level-tip">再获得 {{nextLevelExp - exp}} 经验可升级</text>
    </view>
  </view>

  <!-- 获取方式 -->
  <view class="earn-section">
    <view class="section-title">如何获取积分</view>
    
    <view class="earn-list">
      <view class="earn-item">
        <view class="earn-icon">📅</view>
        <view class="earn-info">
          <text class="earn-title">每日任务</text>
          <text class="earn-desc">完成每日任务获取星光值</text>
        </view>
        <view class="earn-reward">+10~20 🌟</view>
      </view>
      
      <view class="earn-item">
        <view class="earn-icon">🏆</view>
        <view class="earn-info">
          <text class="earn-title">每周挑战</text>
          <text class="earn-desc">完成周挑战获取额外奖励</text>
        </view>
        <view class="earn-reward">+80~150 🌟</view>
      </view>
      
      <view class="earn-item">
        <view class="earn-icon">👯</view>
        <view class="earn-info">
          <text class="earn-title">宿舍任务</text>
          <text class="earn-desc">和舍友一起完成任务</text>
        </view>
        <view class="earn-reward">+30~50 🌟</view>
      </view>
      
      <view class="earn-item">
        <view class="earn-icon">💰</view>
        <view class="earn-info">
          <text class="earn-title">充值</text>
          <text class="earn-desc">充值获取晶钻</text>
        </view>
        <view class="earn-reward">💎</view>
      </view>
    </view>
  </view>

  <!-- 使用方式 -->
  <view class="use-section">
    <view class="section-title">积分用途</view>
    
    <view class="use-list">
      <view class="use-item" bindtap="goToPointsShop">
        <view class="use-icon">🎫</view>
        <view class="use-info">
          <text class="use-title">兑换优惠券</text>
          <text class="use-desc">星光值兑换购物优惠券</text>
        </view>
        <text class="use-arrow">></text>
      </view>
      
      <view class="use-item">
        <view class="use-icon">🎁</view>
        <view class="use-info">
          <text class="use-title">兑换礼品</text>
          <text class="use-desc">更多礼品敬请期待</text>
        </view>
        <text class="use-tip">开发中</text>
      </view>
    </view>
  </view>
</view>
