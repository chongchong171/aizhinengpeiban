/* 我的积分页面样式 */
.container {
  min-height: 100vh;
  background: #FFF5F6;
  padding-bottom: 40rpx;
}

/* 积分总览 */
.points-overview {
  padding: 40rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.points-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.points-card.starlight {
  border: 2rpx solid #FFD700;
}

.points-card.crystal {
  border: 2rpx solid #64DD17;
}

.points-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.points-label {
  font-size: 28rpx;
  color: #666;
  margin: 8rpx 0;
}

.points-desc {
  font-size: 22rpx;
  color: #999;
}

/* 等级区域 */
.level-section {
  margin: 0 30rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.level-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.level-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.level-badge {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  color: #fff;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.level-exp {
  font-size: 26rpx;
  color: #666;
}

.level-progress {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 15rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF6B81 0%, #FF8FA3 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.level-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
}

/* 获取方式 */
.earn-section {
  margin: 0 30rpx 30rpx;
}

.earn-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.earn-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.earn-item:last-child {
  border-bottom: none;
}

.earn-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.earn-info {
  flex: 1;
}

.earn-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.earn-desc {
  font-size: 24rpx;
  color: #999;
}

.earn-reward {
  font-size: 26rpx;
  color: #FF6B81;
  font-weight: bold;
}

/* 使用方式 */
.use-section {
  margin: 0 30rpx;
}

.use-list {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.use-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.use-item:last-child {
  border-bottom: none;
}

.use-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.use-info {
  flex: 1;
}

.use-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.use-desc {
  font-size: 24rpx;
  color: #999;
}

.use-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.use-tip {
  font-size: 24rpx;
  color: #999;
  background: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
