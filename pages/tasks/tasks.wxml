<!--任务页面-->
<view class="container">
  <!-- 头部：我的积分 -->
  <view class="points-header">
    <view class="points-info">
      <text class="points-value">🌟 {{userPoints.starlight}}</text>
      <text class="points-label">星光值</text>
    </view>
    <view class="points-info">
      <text class="points-value">💎 {{userPoints.crystal}}</text>
      <text class="points-label">晶钻</text>
    </view>
  </view>

  <!-- 每日任务 -->
  <view class="task-section">
    <view class="section-header">
      <text class="section-title">每日任务</text>
      <text class="section-subtitle">每天都能做</text>
    </view>
    
    <view class="task-list">
      <view class="task-item {{item.completed ? 'completed' : ''}}" 
            wx:for="{{dailyTasks}}" 
            wx:key="taskType"
            bindtap="claimReward"
            data-item="{{item}}">
        <view class="task-icon">{{item.icon}}</view>
        <view class="task-info">
          <text class="task-name">{{item.taskName}}</text>
          <text class="task-desc">{{item.taskDesc}}</text>
        </view>
        <view class="task-reward">
          <text class="reward-value">+{{item.reward}} 🌟</text>
          <text class="reward-status">{{item.completed ? '已完成' : '去完成'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 每周挑战 -->
  <view class="task-section">
    <view class="section-header">
      <text class="section-title">每周挑战</text>
      <text class="section-subtitle">额外奖励</text>
    </view>
    
    <view class="task-list">
      <view class="task-item {{item.completed ? 'completed' : ''}}" 
            wx:for="{{weeklyTasks}}" 
            wx:key="taskType"
            bindtap="claimReward"
            data-item="{{item}}">
        <view class="task-icon">{{item.icon}}</view>
        <view class="task-info">
          <text class="task-name">{{item.taskName}}</text>
          <text class="task-desc">{{item.taskDesc}}</text>
          <view class="task-progress" wx:if="{{!item.completed}}">
            <text class="progress-text">{{item.progress}}/{{item.target}}</text>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{(item.progress / item.target) * 100}}%"></view>
            </view>
          </view>
        </view>
        <view class="task-reward">
          <text class="reward-value">+{{item.reward}} 🌟</text>
          <text class="reward-status">{{item.completed ? '已完成' : '进行中'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 宿舍集体任务 -->
  <view class="task-section">
    <view class="section-header">
      <text class="section-title">宿舍集体任务</text>
      <text class="section-subtitle">和舍友一起</text>
    </view>
    
    <view class="task-list">
      <view class="task-item {{item.completed ? 'completed' : ''}}" 
            wx:for="{{dormitoryTasks}}" 
            wx:key="taskType"
            bindtap="claimReward"
            data-item="{{item}}">
        <view class="task-icon">{{item.icon}}</view>
        <view class="task-info">
          <text class="task-name">{{item.taskName}}</text>
          <text class="task-desc">{{item.taskDesc}}</text>
          <view class="task-progress" wx:if="{{!item.completed}}">
            <text class="progress-text">{{item.progress}}/{{item.target}}</text>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{(item.progress / item.target) * 100}}%"></view>
            </view>
          </view>
        </view>
        <view class="task-reward">
          <text class="reward-value">+{{item.reward}} 🌟</text>
          <text class="reward-status">{{item.completed ? '已完成' : '进行中'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
