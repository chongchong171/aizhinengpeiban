/* 任务页面样式 */
.container {
  min-height: 100vh;
  background: #FFF5F6;
  padding-bottom: 40rpx;
}

/* 头部积分 */
.points-header {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
}

.points-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 任务区域 */
.task-section {
  margin: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
}

.task-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  transition: all 0.3s;
}

.task-item:last-child {
  margin-bottom: 0;
}

.task-item.completed {
  background: #E8F5E9;
  opacity: 0.7;
}

.task-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.task-progress {
  margin-top: 10rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}

.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B81 0%, #FF8FA3 100%);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.task-reward {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.reward-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-bottom: 6rpx;
}

.reward-status {
  font-size: 22rpx;
  color: #999;
}

.task-item.completed .reward-status {
  color: #4CAF50;
}
