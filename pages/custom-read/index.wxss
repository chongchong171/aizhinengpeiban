/**
 * 瓜瓜读给你听 - 朗读页面样式
 * 温暖治愈系设计
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  padding: 20rpx 30rpx;
  padding-bottom: 100rpx;
}

/* 顶部导航栏 */
.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #FF6B81;
  font-weight: bold;
  padding: 10rpx 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.placeholder {
  width: 80rpx;
}

/* 输入区域 */
.input-section {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.15);
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.text-input {
  width: 100%;
  min-height: 300rpx;
  background-color: #FFF;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  border: 2rpx solid #FFE4E8;
  box-sizing: border-box;
}

.text-input:focus {
  border-color: #FF6B81;
}

/* 选项区域 */
.option-section {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.1);
}

.radio-group {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.radio-item.active {
  background-color: rgba(255, 107, 129, 0.1);
}

.radio-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #FF6B81;
  margin-right: 16rpx;
  position: relative;
}

.radio-circle.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #FF6B81;
}

.radio-item text {
  font-size: 28rpx;
  color: #333;
}

/* 控制按钮区域 */
.control-section {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 50rpx;
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.3);
  transition: all 0.3s;
}

.control-btn:active {
  transform: scale(0.95);
}

.control-btn.disabled {
  opacity: 0.5;
  background: #ccc;
  box-shadow: none;
}

.btn-icon {
  font-size: 48rpx;
  color: #FFF;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #FFF;
  font-weight: 600;
}

/* 播放状态指示器 */
.status-section {
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.playing-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 107, 129, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}

.sound-wave {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E9E 100%);
  margin-right: 20rpx;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.7;
  }
}

.playing-indicator text {
  font-size: 28rpx;
  color: #FF6B81;
  font-weight: 600;
}

/* 朗读列表区域 */
.list-section {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.1);
}

.reading-list {
  margin-top: 20rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #FFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.list-item:active {
  background-color: #FFF5F6;
}

.list-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.list-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.list-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.list-date {
  font-size: 24rpx;
  color: #999;
}

.delete-btn {
  padding: 10rpx 20rpx;
  font-size: 32rpx;
}

.empty-list {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 保存按钮 */
.save-section {
  padding: 20rpx;
}

.save-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7D8 100%);
  color: #FFF;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.3);
  transition: all 0.3s;
}

.save-btn:active {
  transform: scale(0.98);
}
