<!--
  读给你听页面（原瓜瓜读给你听）
  @description 用户上传文字，AI TTS 朗读
  @author 玄枢
  @date 2026-03-15
  @update 女性审美优化：瓜瓜读给你听 → 读给你听
-->

<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-header">
    <view class="back-btn" bindtap="goBack">←</view>
    <!-- 【女性审美优化】瓜瓜读给你听 → 读给你听 -->
    <text class="page-title">{{aiName}}读给你听</text>
    <view class="placeholder"></view>
  </view>

  <!-- 文本输入区域 -->
  <view class="input-section">
    <text class="section-label">📝 输入你想听的内容：</text>
    <textarea 
      class="text-input"
      placeholder="今天天气真好..."
      maxlength="1000"
      auto-height
      value="{{inputText}}"
      bindinput="onTextInput"
    />
  </view>

  <!-- 声音选择 -->
  <view class="option-section">
    <text class="section-label">🔊 声音选择：</text>
    <view class="radio-group">
      <view 
        class="radio-item {{voice === 'female' ? 'active' : ''}}"
        bindtap="selectVoice"
        data-voice="female"
      >
        <view class="radio-circle {{voice === 'female' ? 'checked' : ''}}"></view>
        <text>温柔女声</text>
      </view>
      <view 
        class="radio-item {{voice === 'male' ? 'active' : ''}}"
        bindtap="selectVoice"
        data-voice="male"
      >
        <view class="radio-circle {{voice === 'male' ? 'checked' : ''}}"></view>
        <text>磁性男声</text>
      </view>
    </view>
  </view>

  <!-- 语速选择 -->
  <view class="option-section">
    <text class="section-label">⚡ 语速选择：</text>
    <view class="radio-group">
      <view 
        class="radio-item {{speed === 'slow' ? 'active' : ''}}"
        bindtap="selectSpeed"
        data-speed="slow"
      >
        <view class="radio-circle {{speed === 'slow' ? 'checked' : ''}}"></view>
        <text>慢</text>
      </view>
      <view 
        class="radio-item {{speed === 'medium' ? 'active' : ''}}"
        bindtap="selectSpeed"
        data-speed="medium"
      >
        <view class="radio-circle {{speed === 'medium' ? 'checked' : ''}}"></view>
        <text>中</text>
      </view>
      <view 
        class="radio-item {{speed === 'fast' ? 'active' : ''}}"
        bindtap="selectSpeed"
        data-speed="fast"
      >
        <view class="radio-circle {{speed === 'fast' ? 'checked' : ''}}"></view>
        <text>快</text>
      </view>
    </view>
  </view>

  <!-- 播放控制按钮 -->
  <view class="control-section">
    <view 
      class="control-btn play-btn {{isPlaying ? 'disabled' : ''}}"
      bindtap="playAudio"
    >
      <text class="btn-icon">▶</text>
      <text class="btn-text">播放</text>
    </view>
    <view 
      class="control-btn pause-btn {{!isPlaying ? 'disabled' : ''}}"
      bindtap="pauseAudio"
    >
      <text class="btn-icon">⏸</text>
      <text class="btn-text">暂停</text>
    </view>
  </view>

  <!-- 朗读状态 -->
  <view class="status-section" wx:if="{{isPlaying}}">
    <view class="playing-indicator">
      <view class="sound-wave"></view>
      <text>瓜瓜正在朗读中...</text>
    </view>
  </view>

  <!-- 我的朗读列表 -->
  <view class="list-section">
    <text class="section-label">📚 我的朗读列表：</text>
    <view class="reading-list">
      <view 
        class="list-item" 
        wx:for="{{readingList}}" 
        wx:key="id"
        bindtap="loadReading"
        data-index="{{index}}"
      >
        <text class="list-icon">📄</text>
        <view class="list-content">
          <text class="list-title">{{item.title}}</text>
          <text class="list-date">{{item.date}}</text>
        </view>
        <view class="delete-btn" bindtap="deleteReading" data-index="{{index}}">
          <text>🗑️</text>
        </view>
      </view>
      <view class="empty-list" wx:if="{{readingList.length === 0}}">
        <text>暂无朗读记录，快添加第一条吧~</text>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <view class="save-btn" bindtap="saveReading">
      <text>💾 保存当前朗读</text>
    </view>
  </view>
</view>
