/* pages/dormitory/create/index.wxss - 原生组件版 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  padding: 20rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #FF8E9E;
}

/* 表单区域 */
.form-section {
  background: #FFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.15);
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-of-type {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: #FF6B81;
}

.optional {
  color: #999;
  font-size: 26rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: #FFF5F6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: #FF6B81;
  background: #FFF;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #FFF5F6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-textarea:focus {
  border-color: #FF6B81;
  background: #FFF;
}

.form-tip {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 选择器 */
.selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: #FFF5F6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.selector:active {
  background: #FFE4E8;
}

.selector-text {
  font-size: 30rpx;
  color: #333;
}

.selector-arrow {
  font-size: 40rpx;
  color: #FF6B81;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #FFF5F6;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s;
}

.radio-item.active {
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFF;
}

.radio-circle {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #FF6B81;
  border-radius: 50%;
  margin-right: 12rpx;
  transition: all 0.3s;
}

.radio-circle.checked {
  background: #FF6B81;
  border-color: #FF6B81;
}

.radio-item.active .radio-circle {
  background: #FFF;
  border-color: #FFF;
}

/* 按钮区域 */
.button-section {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.create-button {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #FFF;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.4);
  transition: all 0.3s;
}

.create-button:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.3);
}

.create-button[loading] {
  opacity: 0.8;
}

/* 选择器弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #EEE;
}

.picker-cancel {
  font-size: 30rpx;
  color: #999;
}

.picker-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.picker-confirm {
  font-size: 30rpx;
  color: #FF6B81;
  font-weight: 500;
}

.picker-content {
  max-height: 400rpx;
  overflow-y: auto;
  padding: 20rpx 0;
}

.picker-item {
  padding: 28rpx 60rpx;
  font-size: 32rpx;
  color: #333;
  transition: all 0.2s;
}

.picker-item:active {
  background: #FFF5F6;
}

.picker-item.active {
  color: #FF6B81;
  font-weight: 500;
}
