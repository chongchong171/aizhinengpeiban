<!--
  瓜瓜陪伴微信小程序 - 宿舍创建页面（原生组件版）
  @description 创建女生宿舍，使用原生表单组件
  @author 玄枢
  @date 2026-03-15
-->

<view class="container">
  <!-- 顶部标题区域 -->
  <view class="header">
    <view class="title">🏠 创建女生宿舍</view>
    <view class="subtitle">打造你们的温馨小窝</view>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    
    <!-- 宿舍名称 -->
    <view class="form-item">
      <view class="form-label">宿舍名称 <text class="required">*</text></view>
      <input 
        class="form-input"
        type="text"
        placeholder="给你的宿舍起个名字吧~"
        value="{{formData.dormName}}"
        bindinput="onInputChange"
        data-field="dormName"
        maxlength="20"
      />
      <view class="form-tip">{{formData.dormName ? formData.dormName.length : 0}}/20</view>
    </view>

    <!-- 宿舍风格选择 -->
    <view class="form-item">
      <view class="form-label">宿舍风格 <text class="required">*</text></view>
      <view class="selector" bindtap="showStyleSelector">
        <text class="selector-text">{{formData.style || '请选择宿舍风格'}}</text>
        <text class="selector-arrow">›</text>
      </view>
    </view>

    <!-- 宿舍人数选择 -->
    <view class="form-item">
      <view class="form-label">宿舍人数 <text class="required">*</text></view>
      <view class="radio-group">
        <view 
          class="radio-item {{formData.capacity === 4 ? 'active' : ''}}"
          bindtap="selectCapacity"
          data-value="4"
        >
          <view class="radio-circle {{formData.capacity === 4 ? 'checked' : ''}}"></view>
          <text>4 人</text>
        </view>
        <view 
          class="radio-item {{formData.capacity === 6 ? 'active' : ''}}"
          bindtap="selectCapacity"
          data-value="6"
        >
          <view class="radio-circle {{formData.capacity === 6 ? 'checked' : ''}}"></view>
          <text>6 人</text>
        </view>
        <view 
          class="radio-item {{formData.capacity === 8 ? 'active' : ''}}"
          bindtap="selectCapacity"
          data-value="8"
        >
          <view class="radio-circle {{formData.capacity === 8 ? 'checked' : ''}}"></view>
          <text>8 人</text>
        </view>
      </view>
    </view>

    <!-- 年龄段选择 -->
    <view class="form-item">
      <view class="form-label">年龄段 <text class="required">*</text></view>
      <view class="selector" bindtap="showAgeSelector">
        <text class="selector-text">{{formData.ageGroup || '请选择年龄段'}}</text>
        <text class="selector-arrow">›</text>
      </view>
    </view>

    <!-- 宿舍介绍（选填） -->
    <view class="form-item">
      <view class="form-label">宿舍介绍 <text class="optional">（选填）</text></view>
      <textarea 
        class="form-textarea"
        placeholder="介绍一下你们的宿舍吧~"
        value="{{formData.description}}"
        bindinput="onInputChange"
        data-field="description"
        maxlength="200"
        auto-height
      />
      <view class="form-tip">{{formData.description ? formData.description.length : 0}}/200</view>
    </view>

    <!-- 宿舍公约（选填） -->
    <view class="form-item">
      <view class="form-label">宿舍公约 <text class="optional">（选填）</text></view>
      <textarea 
        class="form-textarea"
        placeholder="例如：互相鼓励、不说伤人的话、保守秘密"
        value="{{formData.agreement}}"
        bindinput="onInputChange"
        data-field="agreement"
        maxlength="100"
        auto-height
      />
      <view class="form-tip">{{formData.agreement ? formData.agreement.length : 0}}/100</view>
      <view class="form-tip-small">💡 公约将展示给所有舍友，共同遵守</view>
    </view>

    <!-- 创建按钮 -->
    <view class="button-section">
      <button class="create-button" bindtap="onSubmit" loading="{{submitting}}">
        {{submitting ? '创建中...' : '创建宿舍'}}
      </button>
    </view>

  </view>

  <!-- 风格选择器 -->
  <view class="picker-mask {{showStylePicker ? 'show' : ''}}" bindtap="hideStylePicker"></view>
  <view class="picker {{showStylePicker ? 'show' : ''}}">
    <view class="picker-header">
      <view class="picker-cancel" bindtap="hideStylePicker">取消</view>
      <view class="picker-title">选择宿舍风格</view>
      <view class="picker-confirm" bindtap="confirmStyle">确定</view>
    </view>
    <view class="picker-content">
      <view 
        class="picker-item {{formData.style === item.label ? 'active' : ''}}"
        wx:for="{{styleOptions}}"
        wx:key="value"
        bindtap="selectStyle"
        data-item="{{item}}"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <!-- 年龄段选择器 -->
  <view class="picker-mask {{showAgePicker ? 'show' : ''}}" bindtap="hideAgePicker"></view>
  <view class="picker {{showAgePicker ? 'show' : ''}}">
    <view class="picker-header">
      <view class="picker-cancel" bindtap="hideAgePicker">取消</view>
      <view class="picker-title">选择年龄段</view>
      <view class="picker-confirm" bindtap="confirmAge">确定</view>
    </view>
    <view class="picker-content">
      <view 
        class="picker-item {{formData.ageGroup === item.label ? 'active' : ''}}"
        wx:for="{{ageOptions}}"
        wx:key="value"
        bindtap="selectAge"
        data-item="{{item}}"
      >
        {{item.label}}
      </view>
    </view>
  </view>

</view>
