/* pages/dormitory/invite/index.wxss */
.container {
  padding: 32rpx;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* 头部区域 */
.header {
  margin-bottom: 40rpx;
}

.dormitory-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.15);
  margin-bottom: 20rpx;
}

.dormitory-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.dormitory-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.dormitory-id {
  font-size: 24rpx;
  color: #999;
}

.header-desc {
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

/* 通用区块样式 */
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

/* 好友网格 */
.friends-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
}

.friend-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: #FFF5F6;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.friend-item:active {
  transform: scale(0.95);
}

.friend-item.selected {
  background: #FFE4E8;
  border-color: #FF6B81;
}

.avatar-wrapper {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 12rpx;
}

.friend-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid #FFD0D5;
}

.check-icon {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.4);
}

.friend-name {
  font-size: 22rpx;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

/* 空好友状态 */
.empty-friends {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 邀请语输入框 */
.invite-message {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: #FFF5F6;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 邀请卡片预览 */
.invite-card {
  background: linear-gradient(135deg, #FFE4E8 0%, #FFF5F6 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 2rpx solid #FFD0D5;
}

.card-header {
  text-align: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed #FFD0D5;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 28rpx;
  color: #666;
}

.card-body {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-message {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 24rpx;
  min-height: 80rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-from,
.card-time {
  font-size: 22rpx;
  color: #999;
}

/* 邀请记录列表 */
.invite-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.invite-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.invite-item:last-child {
  border-bottom: none;
}

.invite-avatar {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.invite-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.invite-detail {
  flex: 1;
  min-width: 0;
}

.invite-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.invite-time {
  font-size: 22rpx;
  color: #999;
}

.invite-status {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.invite-status.accepted {
  background: #E8F5E9;
  color: #4CAF50;
}

.invite-status.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.invite-status.rejected {
  background: #FFEBEE;
  color: #F44336;
}

/* 空记录状态 */
.empty-records {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-generate {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.3);
}

.btn-generate[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.btn-icon {
  font-size: 36rpx;
}

/* 已选好友提示条 */
.selected-bar {
  position: fixed;
  bottom: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.8);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 99;
}

.clear-btn {
  color: #FF8FA3;
  font-weight: 600;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .friends-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
