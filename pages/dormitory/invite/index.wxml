<!--pages/dormitory/invite/index.wxml-->
<view class="container">
  <!-- 头部信息 -->
  <view class="header">
    <view class="dormitory-card">
      <view class="dormitory-icon">🏠</view>
      <view class="dormitory-info">
        <view class="dormitory-name">{{dormitoryName}}</view>
        <view class="dormitory-id">ID: {{dormitoryId}}</view>
      </view>
    </view>
    <view class="header-desc">邀请好友加入你的宿舍</view>
  </view>

  <!-- 微信好友选择区域 -->
  <view class="section">
    <view class="section-title">
      <text class="icon">👥</text>
      选择微信好友
    </view>
    <view class="section-subtitle">最多可选择 5 位好友</view>
    
    <view class="friends-grid">
      <view 
        class="friend-item {{selectedFriends.includes(friend.openId) ? 'selected' : ''}}"
        wx:for="{{friendList}}"
        wx:key="openId"
        data-openid="{{friend.openId}}"
        bindtap="onFriendTap"
      >
        <view class="avatar-wrapper">
          <image class="friend-avatar" src="{{friend.avatarUrl}}" mode="aspectFill" />
          <view class="check-icon" wx:if="{{selectedFriends.includes(friend.openId)}}">✓</view>
        </view>
        <view class="friend-name">{{friend.nickName}}</view>
      </view>
      
      <!-- 空状态提示 -->
      <view class="empty-friends" wx:if="{{friendList.length === 0}}">
        <view class="empty-icon">👻</view>
        <view class="empty-text">暂无好友数据</view>
        <view class="empty-hint">请在微信中添加好友后重试</view>
      </view>
    </view>
  </view>

  <!-- 邀请语输入 -->
  <view class="section">
    <view class="section-title">
      <text class="icon">✏️</text>
      邀请语
    </view>
    <textarea 
      class="invite-message"
      placeholder="写点什么邀请好友吧~（选填）"
      maxlength="200"
      value="{{inviteMessage}}"
      bindinput="onMessageInput"
      auto-height
    />
    <view class="char-count">{{inviteMessage.length}}/200</view>
  </view>

  <!-- 邀请卡片预览 -->
  <view class="section" wx:if="{{inviteCard}}">
    <view class="section-title">
      <text class="icon">🎴</text>
      邀请卡片预览
    </view>
    <view class="invite-card">
      <view class="card-header">
        <view class="card-title">🏠 宿舍邀请</view>
        <view class="card-subtitle">{{dormitoryName}}</view>
      </view>
      <view class="card-body">
        <view class="card-message">{{inviteMessage || '快来加入我们的宿舍吧~'}}</view>
        <view class="card-footer">
          <view class="card-from">邀请人：{{userInfo.nickName || '我'}}</view>
          <view class="card-time">{{currentTime}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 邀请记录 -->
  <view class="section">
    <view class="section-title">
      <text class="icon">📋</text>
      邀请记录
    </view>
    <view class="invite-list">
      <view class="invite-item" wx:for="{{inviteRecords}}" wx:key="_id">
        <view class="invite-avatar">
          <image src="{{item.invitedUserAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        </view>
        <view class="invite-detail">
          <view class="invite-name">{{item.invitedUserName || '微信用户'}}</view>
          <view class="invite-time">{{item.inviteTimeStr}}</view>
        </view>
        <view class="invite-status {{item.status}}">
          {{item.status === 'accepted' ? '已加入' : item.status === 'pending' ? '待处理' : '已拒绝'}}
        </view>
      </view>
      <view class="empty-records" wx:if="{{inviteRecords.length === 0}}">
        <view class="empty-icon">📭</view>
        <view class="empty-text">暂无邀请记录</view>
        <view class="empty-hint">发送邀请后会显示在这里</view>
      </view>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="action-bar">
    <button class="btn-generate" bindtap="onGenerateCard" disabled="{{isGenerating || selectedFriends.length === 0}}">
      <text class="btn-icon">📤</text>
      {{isGenerating ? '发送中...' : '发送邀请'}}
    </button>
  </view>

  <!-- 已选好友提示 -->
  <view class="selected-bar" wx:if="{{selectedFriends.length > 0}}">
    <text>已选择 {{selectedFriends.length}} 位好友</text>
    <text class="clear-btn" bindtap="onClearSelection">清空</text>
  </view>
</view>
