<!--pages/dormitory/index/index.wxml-->
<view class="container" enable-pull-to-refresh="true" bindpullingrefresh="onPullDownRefresh">
  <!-- 未加入宿舍 - 显示创建入口 -->
  <view class="empty-state" wx:if="{{!dormitory}}">
    <view class="empty-icon">🏠</view>
    <view class="empty-title">还没有加入宿舍</view>
    <view class="empty-subtitle">创建一个温馨的女生小窝吧~</view>
    <button class="create-btn" bindtap="goToCreate">创建宿舍</button>
  </view>

  <!-- 宿舍信息卡片 -->
  <view class="dormitory-card" wx:if="{{dormitory}}">
    <view class="dormitory-header">
      <view class="dormitory-name">{{dormitory.name}}</view>
      <view class="dormitory-style">{{dormitory.style}}风</view>
    </view>
    
    <!-- 我的称呼 -->
    <view class="my-title-card" wx:if="{{memberInfo}}">
      <view class="title-label">我的称呼</view>
      <view class="title-content">
        <text class="title-text">{{memberInfo.customTitle || memberInfo.title}}</text>
        <text class="title-edit" bindtap="editTitle">✏️</text>
      </view>
    </view>
    
    <view class="dormitory-info">
      <view class="info-item">
        <text class="label">人数</text>
        <text class="value">{{dormitory.memberCount}}/{{dormitory.capacity}}人</text>
      </view>
      <view class="info-item">
        <text class="label">活跃天数</text>
        <text class="value">{{dormitory.activeDays}}天</text>
      </view>
      <view class="info-item">
        <text class="label">在线</text>
        <text class="value online">{{onlineMembers.length}}人</text>
      </view>
    </view>
    
    <view class="dormitory-intro" wx:if="{{dormitory.introduction}}">
      📝 {{dormitory.introduction}}
    </view>
    
    <!-- 宿舍公约 -->
    <view class="agreement-card" wx:if="{{dormitory.agreement}}">
      <view class="agreement-title">📜 宿舍公约</view>
      <view class="agreement-content">{{dormitory.agreement}}</view>
    </view>
    
    <!-- 纪念日信息 -->
    <view class="anniversary-card" wx:if="{{dormitory.anniversaryInfo}}">
      <view class="anniversary-days">🎉 已相伴 {{dormitory.anniversaryInfo.days}} 天</view>
      <view class="anniversary-message" wx:if="{{dormitory.anniversaryInfo.message}}">
        {{dormitory.anniversaryInfo.message}}
      </view>
      <view class="anniversary-date">
        成立于 {{formatDate(dormitory.anniversaryInfo.createdAt)}}
      </view>
    </view>
  </view>

  <!-- 舍友状态 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">👭 舍友状态</view>
      <view class="section-action" bindtap="goToInvite">邀请+</view>
    </view>
    <view class="roommates-grid">
      <view 
        class="roommate-card" 
        wx:for="{{allMembers}}" 
        wx:key="id"
        bindtap="viewMemberProfile"
        data-member="{{item}}"
      >
        <view class="roommate-avatar-wrapper">
          <image class="roommate-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view class="online-status {{item.isOnline ? 'online' : 'offline'}}"></view>
        </view>
        <view class="roommate-name">{{item.customTitle || item.title || item.name}}</view>
        <view class="roommate-mood" wx:if="{{item.mood}}">{{item.moodEmoji}}</view>
        <view class="roommate-mood-empty" wx:else>
          <text class="set-mood-btn" bindtap="setMoodFor" data-member-id="{{item.id}}">设置心情</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 宿舍动态 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">💬 最新动态</view>
      <view class="section-action" bindtap="goToSpace">查看全部</view>
    </view>
    <view class="posts-list">
      <view class="post-item" wx:for="{{recentPosts}}" wx:key="id">
        <view class="post-header">
          <image class="post-avatar" src="{{item.authorAvatar}}" mode="aspectFill" />
          <view class="post-info">
            <view class="post-author">{{item.authorName}}</view>
            <view class="post-time">{{item.createdAt}}</view>
          </view>
        </view>
        <view class="post-content">{{item.content}}</view>
        <view class="post-actions">
          <view class="action-item">
            <text class="icon">❤️</text>
            <text class="count">{{item.likeCount || 0}}</text>
          </view>
          <view class="action-item">
            <text class="icon">💬</text>
            <text class="count">{{item.commentCount || 0}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{recentPosts.length === 0}}">
        还没有动态，快来发布第一条吧~
      </view>
    </view>
  </view>

  <!-- 今日任务 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">📋 今日宿舍任务</view>
    </view>
    <view class="tasks-list">
      <view 
        class="task-item {{item.completed ? 'completed' : ''}}"
        wx:for="{{todayTasks}}"
        wx:key="id"
        data-task-id="{{item.id}}"
        bindtap="completeTask"
      >
        <view class="task-checkbox">
          <view class="checkbox {{item.completed ? 'checked' : ''}}">
            <text wx:if="{{item.completed}}">✓</text>
          </view>
        </view>
        <view class="task-content">
          <view class="task-title">{{item.title}}</view>
          <view class="task-desc">{{item.description}}</view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{todayTasks.length === 0}}">
        今天没有任务哦~
      </view>
    </view>
  </view>

  <!-- 装修系统入口 -->
  <view class="decoration-section" wx:if="{{dormitory}}">
    <view class="section-header">
      <view class="section-title">🎨 宿舍装修</view>
    </view>
    
    <!-- 宿舍缩略图展示区 -->
    <view class="dorm-preview-card" bindtap="goToDormitoryRoom">
      <view class="preview-image-wrapper">
        <image class="preview-image" src="{{dormitory.previewImage || '/images/default-room.png'}}" mode="aspectFill"></image>
        <view class="preview-overlay">
          <text class="preview-text">点击进入装修</text>
        </view>
      </view>
      <view class="preview-info">
        <view class="preview-name">{{dormitory.name}}</view>
        <view class="preview-stats">
          <text class="stat-item">评分：{{dormitory.score || 0}}</text>
          <text class="stat-item">等级：Lv.{{dormitory.level || 1}}</text>
        </view>
      </view>
    </view>
    
    <!-- 装修快捷入口 -->
    <view class="decoration-actions">
      <view class="deco-btn" bindtap="goToMyDecorations">
        <view class="deco-icon">🎨</view>
        <view class="deco-text">我的装饰</view>
      </view>
      <view class="deco-btn" bindtap="goToDecorationShop">
        <view class="deco-icon">🛒</view>
        <view class="deco-text">装饰商城</view>
      </view>
      <view class="deco-btn" bindtap="goToRanking">
        <view class="deco-icon">🏆</view>
        <view class="deco-text">排行榜</view>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-btn" bindtap="goToSpace">
      <view class="action-icon">💬</view>
      <view class="action-text">宿舍空间</view>
    </view>
    <view class="action-btn" bindtap="goToGoodnight">
      <view class="action-icon">🌙</view>
      <view class="action-text">晚安打卡</view>
    </view>
    <view class="action-btn" bindtap="goToMyDecorations">
      <view class="action-icon">🎨</view>
      <view class="action-text">我的装饰</view>
    </view>
  </view>
</view>
