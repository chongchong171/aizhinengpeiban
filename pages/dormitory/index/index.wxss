/* pages/dormitory/index/index.wxss */
.container {
  padding: 32rpx;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  min-height: 100vh;
}

/* 宿舍信息卡片 */
.dormitory-card {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
}

.dormitory-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.dormitory-name {
  font-size: 44rpx;
  font-weight: bold;
}

.dormitory-style {
  background: rgba(255, 255, 255, 0.3);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.dormitory-info {
  display: flex;
  gap: 48rpx;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item .label {
  font-size: 24rpx;
  opacity: 0.9;
}

.info-item .value {
  font-size: 32rpx;
  font-weight: 600;
}

.info-item .value.online {
  color: #90EE90;
}

.dormitory-intro {
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.95;
  background: rgba(255, 255, 255, 0.15);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

/* 我的称呼卡片 */
.my-title-card {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(10rpx);
}

.title-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.title-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.title-edit {
  font-size: 32rpx;
  opacity: 0.8;
}

/* 宿舍公约卡片 */
.agreement-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  color: #333;
}

.agreement-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B81;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.agreement-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #555;
  padding-left: 20rpx;
  border-left: 4rpx solid #FF6B81;
}

/* 纪念日卡片 */
.anniversary-card {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 193, 7, 0.1) 100%);
  border: 2rpx solid rgba(255, 215, 0, 0.5);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  text-align: center;
}

.anniversary-days {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFD700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.anniversary-message {
  font-size: 28rpx;
  color: #FFF;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.anniversary-date {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 通用区块 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #FF6B81;
}

/* 舍友状态网格 */
.roommates-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.roommate-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #FFF5F6 0%, #FFE4E8 100%);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.roommate-card:active {
  transform: scale(0.95);
}

.roommate-avatar-wrapper {
  position: relative;
  margin-bottom: 12rpx;
}

.roommate-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #FF6B81;
}

.online-status {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.online-status.online {
  background: #4CAF50;
}

.online-status.offline {
  background: #9E9E9E;
}

.roommate-name {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.roommate-mood {
  font-size: 40rpx;
  margin-top: 4rpx;
}

.roommate-mood-empty {
  margin-top: 8rpx;
}

.set-mood-btn {
  font-size: 20rpx;
  color: #FF6B81;
  padding: 4rpx 12rpx;
  background: rgba(255, 107, 129, 0.1);
  border-radius: 12rpx;
}

/* 动态列表 */
.posts-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.post-item:last-child {
  border-bottom: none;
}

.post-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.post-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.post-info {
  flex: 1;
}

.post-author {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.post-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.post-actions {
  display: flex;
  gap: 32rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 26rpx;
}

.action-item .icon {
  font-size: 32rpx;
}

/* 任务列表 */
.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #FFF5F6;
  border-radius: 16rpx;
}

.task-item.completed {
  opacity: 0.6;
}

.task-checkbox {
  flex-shrink: 0;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #FF6B81;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

.checkbox.checked {
  background: #FF6B81;
}

.task-content {
  flex: 1;
}

.task-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 26rpx;
  color: #666;
}

/* 装修系统入口 */
.decoration-section {
  margin-bottom: 32rpx;
}

.dorm-preview-card {
  background: #FFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.15);
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.dorm-preview-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(255, 107, 129, 0.1);
}

.preview-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
  background: linear-gradient(135deg, #FFF5F6 0%, #FFE4E8 100%);
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 107, 129, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
}

.preview-text {
  font-size: 32rpx;
  color: #FFF;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.preview-info {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.preview-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.preview-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #FF6B81;
  font-weight: 500;
}

.decoration-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.deco-btn {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 182, 193, 0.4);
  transition: all 0.3s ease;
}

.deco-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(255, 182, 193, 0.3);
}

.deco-icon {
  font-size: 48rpx;
}

.deco-text {
  font-size: 24rpx;
  color: #FFF;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

/* 快捷入口 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 32rpx;
}

.action-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.1);
}

.action-icon {
  font-size: 56rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

/* 未加入宿舍的空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.1);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
  text-align: center;
}

.create-btn {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
}
