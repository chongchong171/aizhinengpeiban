/* pages/dormitory/space/space.wxss */
.container {
  padding: 32rpx;
  background: linear-gradient(180deg, #FFF5F6 0%, #FFE4E8 100%);
  min-height: 100vh;
}

/* 发布框 */
.publish-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.1);
}

.publish-input-wrapper {
  margin-bottom: 24rpx;
}

.publish-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.publish-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #FFF5F6;
  border-radius: 24rpx;
  color: #666;
  font-size: 28rpx;
}

.action-btn .icon {
  font-size: 32rpx;
}

.publish-btn {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  color: #fff;
  border: none;
  padding: 16rpx 48rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.publish-btn[disabled] {
  opacity: 0.6;
}

/* 动态列表 */
.posts-section {
  position: relative;
  padding-left: 40rpx;
}

.timeline-line {
  position: absolute;
  left: 11rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #FF6B81 0%, #FF8FA3 100%);
  border-radius: 2rpx;
}

.post-item {
  position: relative;
  margin-bottom: 40rpx;
}

.post-timeline-dot {
  position: absolute;
  left: -36rpx;
  top: 32rpx;
  width: 24rpx;
  height: 24rpx;
  background: #FF6B81;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 129, 0.3);
}

.post-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.1);
}

.post-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #FF6B81;
}

.post-info {
  flex: 1;
}

.post-author {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.post-time {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.post-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 24rpx;
  word-break: break-all;
}

/* 图片网格 */
.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.post-image {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #f5f5f5;
}

/* 互动区域 */
.post-interactions {
  display: flex;
  gap: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.interaction-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 28rpx;
  padding: 12rpx 20rpx;
  background: #FFF5F6;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.interaction-btn .icon {
  font-size: 32rpx;
}

.interaction-btn.liked {
  color: #FF6B81;
  background: #FFE4E8;
}

.comfort-btn {
  background: #FFF9E6;
  color: #FF9800;
}

.comfort-btn:active {
  background: #FFE4E8;
  color: #FF6B81;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
