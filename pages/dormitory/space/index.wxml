<!--pages/dormitory/space/space.wxml-->
<view class="container" enable-pull-to-refresh="true" bindpullingrefresh="onPullDownRefresh">
  <!-- 发布框 -->
  <view class="publish-box">
    <view class="publish-input-wrapper">
      <textarea 
        class="publish-input" 
        placeholder="分享你的心情吧~" 
        value="{{newContent}}"
        bindinput="onContentInput"
        maxlength="500"
        auto-height
      />
    </view>
    <view class="publish-actions">
      <view class="action-btn" bindtap="onChooseImage">
        <text class="icon">📷</text>
        <text class="text">图片</text>
      </view>
      <button class="publish-btn" bindtap="onPublish" disabled="{{isPosting}}">
        {{isPosting ? '发布中...' : '发布'}}
      </button>
    </view>
  </view>

  <!-- 动态列表 -->
  <view class="posts-section">
    <view class="timeline-line"></view>
    
    <view class="post-item" wx:for="{{posts}}" wx:key="id">
      <view class="post-timeline-dot"></view>
      
      <view class="post-card">
        <view class="post-header">
          <image class="post-avatar" src="{{item.authorAvatar}}" mode="aspectFill" />
          <view class="post-info">
            <view class="post-author">{{item.authorName}}</view>
            <view class="post-time">{{item.createdAt}}</view>
          </view>
        </view>
        
        <view class="post-content">
          {{item.content}}
        </view>
        
        <!-- 图片网格（预留） -->
        <view class="post-images" wx:if="{{item.images && item.images.length > 0}}">
          <image 
            class="post-image" 
            wx:for="{{item.images}}" 
            wx:key="*this"
            src="{{item}}" 
            mode="aspectFill"
          />
        </view>
        
        <!-- 互动区域 -->
        <view class="post-interactions">
          <view 
            class="interaction-btn {{item.isLiked ? 'liked' : ''}}"
            data-post-id="{{item.id}}"
            bindtap="onLike"
          >
            <text class="icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
            <text class="count">{{item.likeCount || 0}}</text>
          </view>
          
          <view class="interaction-btn">
            <text class="icon">💬</text>
            <text class="count">{{item.commentCount || 0}}</text>
          </view>
          
          <view 
            class="interaction-btn comfort-btn"
            data-post-id="{{item.id}}"
            data-type="hug"
            bindtap="onComfort"
          >
            <text class="icon">🤗</text>
            <text class="text">拥抱</text>
          </view>
          
          <view 
            class="interaction-btn comfort-btn"
            data-post-id="{{item.id}}"
            data-type="comfort"
            bindtap="onComfort"
          >
            <text class="icon">💕</text>
            <text class="text">安慰</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{posts.length === 0}}">
      <view class="empty-icon">💬</view>
      <view class="empty-text">还没有动态</view>
      <view class="empty-subtext">快来发布第一条宿舍动态吧~</view>
    </view>
    
    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{hasMore && posts.length > 0}}">
      <text>加载中...</text>
    </view>
    
    <view class="no-more" wx:if="{{!hasMore && posts.length > 0}}">
      <text>没有更多了</text>
    </view>
  </view>
</view>
