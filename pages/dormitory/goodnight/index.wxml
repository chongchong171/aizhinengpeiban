<!--pages/dormitory/goodnight/goodnight.wxml-->
<view class="container">
  <!-- 顶部时间提示 -->
  <view class="time-header">
    <view class="time-icon">{{isSleepTime ? '🌙' : '🌆'}}</view>
    <view class="time-text">{{isSleepTime ? '夜深啦' : '晚上好'}}</view>
    <view class="time-subtext" wx:if="{{isSleepTime}}">该准备睡觉啦~</view>
  </view>

  <!-- 打卡状态卡片 -->
  <view class="checkin-card {{hasCheckedIn ? 'checked' : ''}}">
    <view class="checkin-status">
      <view class="status-icon">{{hasCheckedIn ? '✅' : '🌙'}}</view>
      <view class="status-text">
        {{hasCheckedIn ? '已说晚安' : '还没说晚安哦'}}
      </view>
      <view class="status-time" wx:if="{{checkInTime}}">
        打卡时间：{{checkInTime}}
      </view>
    </view>
    
    <button 
      class="checkin-btn" 
      bindtap="onCheckIn" 
      disabled="{{hasCheckedIn}}"
      wx:if="{{!hasCheckedIn}}"
    >
      说晚安
    </button>
    
    <view class="checked-in-tip" wx:if="{{hasCheckedIn}}">
      ✨ 今晚好梦
    </view>
  </view>

  <!-- 打卡统计 -->
  <view class="stats-section">
    <view class="stats-title">今日晚安情况</view>
    <view class="stats-progress">
      <view class="progress-bar">
        <view 
          class="progress-fill" 
          style="width: {{totalCount > 0 ? (checkedInCount / totalCount * 100) : 0}}%"
        ></view>
      </view>
      <view class="progress-text">
        {{checkedInCount}}/{{totalCount}} 人已打卡
      </view>
    </view>
  </view>

  <!-- 舍友打卡列表 -->
  <view class="members-section">
    <view class="section-title">舍友晚安</view>
    <view class="members-list">
      <view 
        class="member-item {{item.checkedIn ? 'checked' : ''}}"
        wx:for="{{todayCheckins}}"
        wx:key="id"
      >
        <view class="member-avatar-wrapper">
          <image class="member-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view class="check-icon" wx:if="{{item.checkedIn}}">🌙</view>
        </view>
        <view class="member-info">
          <view class="member-name">{{item.name}}</view>
          <view class="member-status">
            {{item.checkedIn ? '已说晚安' : '还没睡'}}
          </view>
        </view>
        <view class="member-time" wx:if="{{item.checkInTime}}">
          {{item.checkInTime}}
        </view>
      </view>
      
      <view class="empty-tip" wx:if="{{todayCheckins.length === 0}}">
        暂无数据
      </view>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-section">
    <view class="tips-title">💡 睡前小贴士</view>
    <view class="tips-list">
      <view class="tip-item">
        <text class="tip-icon">📱</text>
        <text class="tip-text">睡前少看手机，保护眼睛</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">🥛</text>
        <text class="tip-text">可以喝杯温牛奶助眠</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">🎵</text>
        <text class="tip-text">听点轻音乐放松身心</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon">😴</text>
        <text class="tip-text">保持 7-8 小时睡眠哦</text>
      </view>
    </view>
  </view>

  <!-- 历史记录入口 -->
  <view class="history-btn" bindtap="goToHistory">
    <text class="icon">📅</text>
    <text class="text">查看打卡历史</text>
  </view>
</view>

<!-- 防沉迷提醒弹窗 -->
<view class="sleep-reminder-modal" wx:if="{{showSleepReminder}}">
  <view class="modal-mask" bindtap="onSleepReminderLater"></view>
  <view class="modal-content">
    <view class="modal-icon">😴</view>
    <view class="modal-title">该睡觉啦！</view>
    <view class="modal-text">
      已经 23 点啦，\n早点休息对身体好哦~
    </view>
    <view class="modal-buttons">
      <button class="btn-later" bindtap="onSleepReminderLater">
        再玩一会儿
      </button>
      <button class="btn-sleep" bindtap="onSleepReminderConfirm">
        去睡觉
      </button>
    </view>
  </view>
</view>
