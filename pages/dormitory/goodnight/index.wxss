/* pages/dormitory/goodnight/index.wxss - 夜间模式样式 */

/* 夜空渐变背景 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #2D1B4E 50%, #4E2D5B 100%);
  padding: 20rpx;
}

/* 月亮装饰 */
.moon-decoration {
  position: fixed;
  top: 100rpx;
  right: 50rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle at 30% 30%, #FFF9C4, #FFD54F);
  border-radius: 50%;
  box-shadow: 0 0 60rpx rgba(255, 213, 79, 0.6);
  animation: moonGlow 3s ease-in-out infinite;
}

@keyframes moonGlow {
  0%, 100% { opacity: 0.8; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

/* 星星装饰 */
.stars-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  background-image: 
    radial-gradient(2rpx 2rpx at 50rpx 50rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(2rpx 2rpx at 150rpx 100rpx, rgba(255,255,255,0.6), transparent),
    radial-gradient(2rpx 2rpx at 250rpx 200rpx, rgba(255,255,255,0.7), transparent);
  background-size: 300rpx 300rpx;
  animation: twinkle 2s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* 打卡卡片 */
.checkin-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin: 30rpx 20rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.checkin-title {
  font-size: 36rpx;
  color: #FFD54F;
  text-align: center;
  margin-bottom: 30rpx;
  font-weight: bold;
}

/* 输入框 */
.goodnight-input {
  width: 100%;
  min-height: 200rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFF;
  font-size: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.goodnight-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* 音乐选择 */
.music-selector {
  margin-top: 40rpx;
}

.music-title {
  font-size: 32rpx;
  color: #E0C3F7;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.music-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.music-option {
  flex: 1;
  min-width: 120rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.music-option.selected {
  background: rgba(224, 195, 247, 0.3);
  border-color: #E0C3F7;
}

.music-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.music-name {
  font-size: 24rpx;
  color: #FFF;
}

/* 打卡按钮 */
.checkin-button {
  background: linear-gradient(135deg, #E0C3F7 0%, #C7A8E8 100%);
  color: #FFF;
  font-size: 32rpx;
  font-weight: bold;
  padding: 30rpx 60rpx;
  border-radius: 50rpx;
  margin: 40rpx auto;
  display: block;
  width: fit-content;
  box-shadow: 0 8rpx 24rpx rgba(224, 195, 247, 0.4);
}

/* 舍友列表 */
.roommates-section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  color: #E0C3F7;
  margin-bottom: 20rpx;
  font-weight: bold;
  padding-left: 20rpx;
}

.roommate-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.roommate-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 3rpx solid #E0C3F7;
}

.roommate-info {
  flex: 1;
}

.roommate-name {
  font-size: 30rpx;
  color: #FFF;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.roommate-message {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 防沉迷提醒 */
.sleep-reminder {
  background: linear-gradient(135deg, #FF6B6B, #FF5252);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 30rpx 20rpx;
  text-align: center;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

.reminder-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.reminder-text {
  font-size: 28rpx;
  color: #FFF;
  font-weight: bold;
  line-height: 1.6;
}

/* 统计数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 30rpx 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  color: #FFD54F;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}
