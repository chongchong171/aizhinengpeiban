/* 积分商城页面样式 */
.container {
  min-height: 100vh;
  background: #FFF5F6;
  padding-bottom: 40rpx;
}

/* 头部积分卡片 */
.points-header {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  padding: 40rpx 30rpx 60rpx;
  position: relative;
}

.points-card {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 30rpx;
  backdrop-filter: blur(10rpx);
}

.points-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.rules-btn {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 优惠券区域 */
.coupon-section {
  margin-top: -30rpx;
  background: #FFF5F6;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coupon-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.coupon-left {
  flex: 1;
}

.coupon-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.value-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-right: 8rpx;
}

.value-desc {
  font-size: 24rpx;
  color: #999;
}

.coupon-condition {
  font-size: 24rpx;
  color: #666;
  background: #FFF5F6;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.coupon-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.coupon-cost {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B81;
}

.coupon-discount {
  font-size: 24rpx;
  color: #999;
}

.coupon-limit {
  font-size: 22rpx;
  color: #ccc;
}

/* 提示区域 */
.tips-section {
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-content text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 跳转按钮 */
.jump-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 129, 0.3);
}

.jump-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.btn-text {
  font-weight: 500;
}
