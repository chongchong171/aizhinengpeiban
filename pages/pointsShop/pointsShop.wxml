<!--积分商城页面-->
<view class="container">
  <!-- 头部：我的积分 -->
  <view class="points-header">
    <view class="points-card">
      <view class="points-main">
        <text class="points-value">{{userPoints.starlight}}</text>
        <text class="points-label">星光值 🌟</text>
      </view>
      <view class="points-sub">
        <text>晶钻 💎 {{userPoints.crystal}}</text>
      </view>
    </view>
    <view class="rules-btn" bindtap="showRules">
      兑换规则
    </view>
  </view>

  <!-- ⚠️ 核心规则提示 -->
  <view class="core-rule">
    <text class="rule-icon">⚠️</text>
    <text class="rule-text">星光值和晶钻在爻光晶舍不可叠加使用，二选一！</text>
  </view>

  <!-- 🌟 星光值折扣券（个人活跃） -->
  <view class="coupon-section">
    <view class="section-title">🌟 星光值折扣券</view>
    <view class="section-desc">完成个人任务获取，约 200 分/天</view>
    
    <!-- 店铺信息 -->
    <view class="shop-info">
      <view class="shop-icon">🏪</view>
      <view class="shop-content">
        <text class="shop-name">小红书 · 爻光晶舍</text>
        <text class="shop-desc">兑换后联系客服号 yg-crystal 获取兑换码</text>
      </view>
    </view>
    
    <view class="coupon-list">
      <view class="coupon-item starlight" wx:for="{{starlightCoupons}}" wx:key="couponType">
        <view class="coupon-left">
          <view class="coupon-value">
            <text class="value-num">{{item.couponValue}}折</text>
            <text class="value-desc">水晶折扣券</text>
          </view>
          <view class="coupon-condition" wx:if="{{item.minPurchase > 0}}">
            满¥{{item.minPurchase}}可用
          </view>
          <view class="coupon-condition" wx:else>
            无门槛
          </view>
        </view>
        <view class="coupon-right">
          <view class="coupon-cost">{{item.pointsCost}} 星光值</view>
          <view class="coupon-days">{{item.estimateDays}}</view>
          <view class="coupon-contact">📮 yg-crystal</view>
          <!-- 跳转按钮 -->
          <view class="jump-btn" bindtap="jumpToXiaohongshu" data-coupon-id="{{item.couponType}}" data-coupon-amount="{{item.couponValue}}">
            <text class="btn-icon">🛍️</text>
            <text class="btn-text">去使用</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 💎 晶钻抵扣券（集体任务） -->
  <view class="coupon-section">
    <view class="section-title">💎 晶钻抵扣券</view>
    <view class="section-desc">完成集体任务获取，约 15 分/天</view>
    
    <view class="coupon-list">
      <view class="coupon-item crystal" wx:for="{{crystalCoupons}}" wx:key="couponType">
        <view class="coupon-left">
          <view class="coupon-value">
            <text class="value-num">抵¥{{item.couponValue}}</text>
            <text class="value-desc">现金抵扣券</text>
          </view>
          <view class="coupon-condition">
            无门槛
          </view>
        </view>
        <view class="coupon-right">
          <view class="coupon-cost">{{item.pointsCost}} 晶钻</view>
          <view class="coupon-days">{{item.estimateDays}}</view>
          <view class="coupon-bonus" wx:if="{{item.bonusRate > 0}}">额外赠送 {{item.bonusRate}}%</view>
          <view class="coupon-contact">📮 yg-crystal</view>
          <!-- 跳转按钮 -->
          <view class="jump-btn" bindtap="jumpToXiaohongshu" data-coupon-id="{{item.couponType}}" data-coupon-amount="{{item.couponValue}}">
            <text class="btn-icon">🛍️</text>
            <text class="btn-text">去使用</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section">
    <view class="tips-title">使用说明</view>
    <view class="tips-content">
      <text>1. 兑换后联系客服号 yg-crystal 获取兑换码</text>
      <text>2. 在小红书爻光晶舍店铺购买水晶时使用</text>
      <text>3. 星光值和晶钻不可叠加使用，二选一</text>
      <text>4. 星光值通过个人任务获取（约 200 分/天）</text>
      <text>5. 晶钻通过集体任务获取（约 15 分/天）</text>
    </view>
  </view>
</view>
