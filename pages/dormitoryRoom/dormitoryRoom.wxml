<!--pages/dormitoryRoom/dormitoryRoom.wxml-->
<!-- 宿舍装修展示页面 - 2D 俯视图 -->

<view class="container">
  <!-- 顶部宿舍信息栏 -->
  <view class="dorm-info">
    <view class="dorm-name">{{dormitory.name}}</view>
    <view class="dorm-level">
      <text class="level-badge">Lv.{{dormitory.level}}</text>
      <text class="score">评分：{{dormitory.score}}</text>
    </view>
    <view class="owner-info">
      <image class="owner-avatar" src="{{dormitory.ownerAvatar}}" mode="aspectFill"></image>
      <text class="owner-name">{{dormitory.ownerName}}</text>
    </view>
  </view>

  <!-- 宿舍 2D 俯视图区域 -->
  <view class="room-view" id="roomView">
    <!-- 地板背景 -->
    <view class="room-floor" style="background-image: url({{floorImage}});"></view>
    
    <!-- 壁纸背景 -->
    <view class="room-wall" style="background-image: url({{wallpaperImage}});"></view>
    
    <!-- 网格布局 -->
    <view class="room-grid" style="grid-template-columns: repeat({{gridSize}}, 1fr); grid-template-rows: repeat({{gridSize}}, 1fr);">
      <!-- 可放置装饰品的格子 -->
      <block wx:for="{{gridCells}}" wx:key="id">
        <view 
          class="grid-cell {{item.occupied ? 'occupied' : ''}}" 
          data-id="{{item.id}}"
          data-row="{{item.row}}"
          data-col="{{item.col}}"
          bindtap="onGridTap"
        >
          <!-- 放置的装饰品 -->
          <view 
            wx:if="{{item.decoration}}"
            class="decoration-item {{item.selected ? 'selected' : ''}}"
            style="left: {{item.left}}px; top: {{item.top}}px; transform: rotate({{item.rotation}}deg);"
            data-id="{{item.decoration.id}}"
            data-grid-id="{{item.id}}"
            bindlongpress="onDecorationLongPress"
            catchtap="onDecorationTap"
          >
            <image class="decoration-img" src="{{item.decoration.icon}}" mode="aspectFit"></image>
          </view>
        </view>
      </block>
    </view>

    <!-- 拖拽中的装饰品 -->
    <view 
      wx:if="{{draggingDecoration}}"
      class="dragging-decoration"
      style="left: {{dragX}}px; top: {{dragY}}px;"
    >
      <image class="decoration-img" src="{{draggingDecoration.icon}}" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 装修工具栏 -->
  <view class="toolbar">
    <view class="toolbar-tabs">
      <view 
        class="toolbar-tab {{activeTool === 'move' ? 'active' : ''}}"
        bindtap="switchTool"
        data-tool="move"
      >
        <text class="tool-icon">✋</text>
        <text class="tool-name">移动</text>
      </view>
      <view 
        class="toolbar-tab {{activeTool === 'rotate' ? 'active' : ''}}"
        bindtap="switchTool"
        data-tool="rotate"
      >
        <text class="tool-icon">🔄</text>
        <text class="tool-name">旋转</text>
      </view>
      <view 
        class="toolbar-tab {{activeTool === 'delete' ? 'active' : ''}}"
        bindtap="switchTool"
        data-tool="delete"
      >
        <text class="tool-icon">🗑️</text>
        <text class="tool-name">删除</text>
      </view>
      <view 
        class="toolbar-tab {{activeTool === 'buy' ? 'active' : ''}}"
        bindtap="switchTool"
        data-tool="buy"
      >
        <text class="tool-icon">🛒</text>
        <text class="tool-name">购买</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="toolbar-actions">
      <button class="action-btn cancel-btn" bindtap="cancelOperation">取消</button>
      <button class="action-btn save-btn" bindtap="saveDecoration">保存</button>
    </view>
  </view>

  <!-- 装饰品选择弹窗 -->
  <view wx:if="{{showDecorationSelect}}" class="modal-overlay" bindtap="closeDecorationSelect">
    <view class="modal-content" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">选择装饰品</text>
        <text class="modal-close" bindtap="closeDecorationSelect">✕</text>
      </view>
      <view class="decoration-grid">
        <block wx:for="{{myDecorations}}" wx:key="id">
          <view 
            class="decoration-option {{item.selected ? 'selected' : ''}}"
            bindtap="selectDecoration"
            data-id="{{item.id}}"
          >
            <image class="decoration-option-img" src="{{item.icon}}" mode="aspectFit"></image>
            <text class="decoration-option-name">{{item.name}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 购买确认弹窗 -->
  <view wx:if="{{showBuyConfirm}}" class="modal-overlay" bindtap="closeBuyConfirm">
    <view class="modal-content buy-modal" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">确认购买</text>
        <text class="modal-close" bindtap="closeBuyConfirm">✕</text>
      </view>
      <view class="buy-info">
        <image class="buy-item-img" src="{{selectedDecoration.icon}}" mode="aspectFit"></image>
        <view class="buy-item-details">
          <text class="buy-item-name">{{selectedDecoration.name}}</text>
          <text class="buy-item-price">💰 {{selectedDecoration.price}} 星光值</text>
        </view>
      </view>
      <view class="buy-actions">
        <button class="action-btn cancel-btn" bindtap="closeBuyConfirm">取消</button>
        <button class="action-btn confirm-btn" bindtap="confirmBuy">确认购买</button>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view wx:if="{{toastMessage}}" class="toast">{{toastMessage}}</view>
</view>
