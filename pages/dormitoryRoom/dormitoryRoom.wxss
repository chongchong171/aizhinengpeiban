/* pages/dormitoryRoom/dormitoryRoom.wxss */
/* 宿舍装修展示页面 - 温暖治愈系粉色系风格 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E9 100%);
}

/* 顶部宿舍信息栏 */
.dorm-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-bottom: 4rpx solid #FF69B4;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.dorm-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFF;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.dorm-level {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.level-badge {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #FFF;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(255, 215, 0, 0.4);
}

.score {
  font-size: 22rpx;
  color: #FFF;
  margin-top: 8rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.owner-info {
  display: flex;
  align-items: center;
}

.owner-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid #FFF;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.owner-name {
  font-size: 24rpx;
  color: #FFF;
  margin-left: 12rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

/* 宿舍 2D 俯视图区域 */
.room-view {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: #FFF8DC;
}

.room-floor {
  position: absolute;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
}

.room-wall {
  position: absolute;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  opacity: 0.1;
}

.room-grid {
  position: relative;
  width: 100%;
  height: 100%;
  display: grid;
}

.grid-cell {
  position: relative;
  border: 2rpx dashed rgba(255, 182, 193, 0.5);
  box-sizing: border-box;
  transition: all 0.3s;
}

.grid-cell.occupied {
  border: 2rpx solid rgba(255, 105, 180, 0.3);
  background: rgba(255, 182, 193, 0.1);
}

.grid-cell:active {
  background: rgba(255, 182, 193, 0.2);
}

.decoration-item {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s;
  z-index: 10;
}

.decoration-item.selected {
  box-shadow: 0 0 20rpx rgba(255, 105, 180, 0.8);
  border-radius: 10rpx;
  background: rgba(255, 182, 193, 0.3);
}

.decoration-img {
  width: 80%;
  height: 80%;
  object-fit: contain;
}

.dragging-decoration {
  position: fixed;
  width: 120rpx;
  height: 120rpx;
  z-index: 1000;
  pointer-events: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}

/* 装修工具栏 */
.toolbar {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-top: 4rpx solid #FF69B4;
  box-shadow: 0 -4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.toolbar-tabs {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.toolbar-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.toolbar-tab.active {
  background: rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(255, 255, 255, 0.5);
  transform: translateY(-4rpx);
}

.tool-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tool-name {
  font-size: 22rpx;
  color: #FFF;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.toolbar-actions {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx 30rpx;
}

.action-btn {
  flex: 1;
  margin: 0 10rpx;
  padding: 20rpx 0;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s;
}

.action-btn:active {
  transform: scale(0.95);
}

.cancel-btn {
  background: linear-gradient(135deg, #FFA07A 0%, #FF8C69 100%);
  color: #FFF;
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #98FB98 0%, #90EE90 100%);
  color: #FFF;
  border: none;
}

.confirm-btn {
  background: linear-gradient(135deg, #FF69B4 0%, #FF1493 100%);
  color: #FFF;
  border: none;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.modal-content {
  background: #FFF;
  border-radius: 30rpx;
  width: 90%;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-bottom: 2rpx solid #FF69B4;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFF;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.modal-close {
  font-size: 40rpx;
  color: #FFF;
  padding: 10rpx;
  line-height: 1;
}

.decoration-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.decoration-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #FFF5F7;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.decoration-option.selected {
  border-color: #FF69B4;
  background: rgba(255, 105, 180, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.decoration-option-img {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  object-fit: contain;
}

.decoration-option-name {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

/* 购买弹窗 */
.buy-modal {
  width: 80%;
}

.buy-info {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: #FFF5F7;
}

.buy-item-img {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
  object-fit: contain;
}

.buy-item-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.buy-item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.buy-item-price {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
}

.buy-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
}

/* 提示信息 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  color: #FFF;
  padding: 24rpx 40rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  z-index: 3000;
  animation: toastFade 0.3s ease-out;
}

@keyframes toastFade {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.8);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}
