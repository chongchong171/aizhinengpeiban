/**
 * AI 命名引导页面样式
 * @description 温暖治愈系设计，粉色调，圆角元素
 * @author 玄枢
 * @date 2026-03-15
 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E9 100%);
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 欢迎区域 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.welcome-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B81;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 32rpx;
  color: #FF8FA3;
  margin-bottom: 24rpx;
}

.welcome-message {
  font-size: 28rpx;
  color: #8B7D8B;
  text-align: center;
  line-height: 1.8;
  white-space: pre-line;
}

/* 输入区域 */
.input-section {
  width: 100%;
  margin-bottom: 50rpx;
}

.input-label {
  display: block;
  font-size: 30rpx;
  color: #5A4A5A;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.input-wrapper {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.15);
  border: 2rpx solid #FFE4E9;
}

.name-input {
  font-size: 36rpx;
  color: #333333;
  text-align: center;
  width: 100%;
}

.input-placeholder {
  color: #CCCCCC;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-top: 16rpx;
}

/* 推荐名字区域 */
.recommend-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #5A4A5A;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.recommend-item {
  background: #FFFFFF;
  border: 2rpx solid #FFE4E9;
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #FF6B81;
  transition: all 0.3s ease;
}

.recommend-item.selected,
.recommend-item:active {
  background: #FF6B81;
  color: #FFFFFF;
  border-color: #FF6B81;
  transform: scale(1.05);
}

/* 确认按钮区域 */
.action-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: #FFCDD5;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 129, 0.2);
}

.confirm-btn.active {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8FA3 100%);
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 129, 0.35);
}

.confirm-btn.active:active {
  transform: scale(0.98);
}

/* 底部装饰 */
.footer-decoration {
  margin-top: auto;
  padding-top: 40rpx;
}

.footer-text {
  font-size: 26rpx;
  color: #FF8FA3;
  text-align: center;
}

/* 按钮禁用状态 */
button[disabled] {
  opacity: 0.6;
}
