<!--
  AI 命名引导页面
  @description 首次使用时让用户给 AI 取名字
  @author 玄枢
  @date 2026-03-15
-->

<view class="container">
  <!-- 顶部欢迎区域 -->
  <view class="welcome-section">
    <view class="welcome-icon">🐾</view>
    <text class="welcome-title">你好呀！</text>
    <text class="welcome-subtitle">我是你的专属陪伴小 AI</text>
    <text class="welcome-message">
      在开始陪伴你之前，\n我想请你给我取个名字~
    </text>
  </view>

  <!-- 名字输入区域 -->
  <view class="input-section">
    <text class="input-label">你希望我叫什么呢？</text>
    <view class="input-wrapper">
      <input 
        class="name-input" 
        type="text" 
        placeholder="请输入名字（2-4 个字）" 
        placeholder-class="input-placeholder"
        value="{{inputName}}"
        bindinput="onInputChange"
        maxlength="4"
      />
    </view>
    <text class="input-hint">名字会保存在本地，随时可以修改哦~</text>
  </view>

  <!-- 推荐名字区域 -->
  <view class="recommend-section">
    <text class="section-label">✨ 推荐名字</text>
    <view class="recommend-list">
      <view 
        class="recommend-item {{selectedRecommend === item ? 'selected' : ''}}" 
        wx:for="{{recommendNames}}" 
        wx:key="*this"
        bindtap="selectRecommend"
        data-name="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 确认按钮 -->
  <view class="action-section">
    <button 
      class="confirm-btn {{canConfirm ? 'active' : ''}}" 
      bindtap="confirmName"
      disabled="{{!canConfirm}}"
    >
      确认名字，开始陪伴
    </button>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-decoration">
    <text class="footer-text">💕 从此以后，我就是你的{{inputName || '小 AI'}}啦~</text>
  </view>
</view>
