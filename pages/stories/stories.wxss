/**
 * 睡前故事页面样式
 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F6 0%, #E8D5F0 100%);
  padding: 40rpx 30rpx 160rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  padding: 10rpx 0;
}

.tab-item {
  flex-shrink: 0;
  background-color: rgba(255, 255, 255, 0.6);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active {
  background-color: #FF6B81;
  color: #FFFFFF;
}

/* 故事滚动列表 */
.story-scroll {
  height: calc(100vh - 300rpx);
}

.story-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 故事卡片 */
.story-card {
  display: flex;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.story-cover {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #FF6B81 0%, #E8D5F0 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.story-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.story-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.story-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.story-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 播放控制栏 */
.player-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.95);
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #EEE;
  backdrop-filter: blur(10rpx);
}

.player-info {
  display: flex;
  flex-direction: column;
}

.playing-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.playing-status {
  font-size: 22rpx;
  color: #999;
}

.playing-time {
  font-size: 20rpx;
  color: #FF6B81;
  margin-top: 4rpx;
}

.player-controls {
  display: flex;
  gap: 20rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #FF6B81;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 详情弹窗内容 */
.detail-content {
  padding: 20rpx 0;
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.detail-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

/* 自定义弹窗样式 */
.custom-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.custom-dialog {
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: dialogSlideIn 0.3s ease-out;
}

@keyframes dialogSlideIn {
  from {
    opacity: 0;
    transform: translateY(-50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.dialog-title {
  text-align: center;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #EEE;
}

.dialog-content {
  padding: 40rpx 30rpx;
}

.dialog-footer {
  display: flex;
  border-top: 1rpx solid #EEE;
}

.dialog-cancel,
.dialog-confirm {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #666;
}

.dialog-cancel {
  border-right: 1rpx solid #EEE;
  background-color: #F8F8F8;
}

.dialog-confirm {
  color: #FF6B81;
  font-weight: 600;
}
