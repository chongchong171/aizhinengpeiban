# Auto detect text files and perform LF normalization
* text=auto eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf

# WeChat Mini Program
*.wxml text eol=lf
*.wxss text eol=lf
*.wxs text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary